      '<td style="font-size:11px;color:var(--text-muted);">' + log.detail + '</td></tr>';
  }).join('');
  tbody.innerHTML = rows || '<tr><td colspan="7" style="text-align:center;padding:30px;color:var(--text-muted);">暂无操作日志</td></tr>';
}

