<script>
// 【物联后台v4-第X轮-改进】首页搜索防抖优化P60
// 理由：搜索输入无防抖，每次按键立即执行过滤，性能差用户体验也不好
function debounceFilterRooms(kw) {
  if (window._filterRoomsTimer) clearTimeout(window._filterRoomsTimer);
  window._filterRoomsTimer = setTimeout(function() {
    filterRoomsByKeyword(kw);
  }, 300);
}
function filterRoomsByKeyword(kw) {
  var cards = document.querySelectorAll('#room-grid .room-card');
  kw = kw.trim().toLowerCase();
  cards.forEach(function(c) {
    var room = c.dataset.room || '';
    var text = c.textContent.toLowerCase();
    var match = !kw || room.toLowerCase().includes(kw) || text.includes(kw);
    c.style.display = match ? '' : 'none';
  });
}
</script>
