function submitAnnouncement() {
  var title = document.getElementById('ann-title').value.trim();
  var content = document.getElementById('ann-content').value.trim();
  var type = document.getElementById('ann-type').value;
  var scope = document.getElementById('ann-scope').value;
  var push = document.getElementById('ann-push').value;
  if (!title || !content) { showToast('请填写标题和内容', 'error'); return; }
  var newAnn = {
    id: 'ANN-' + Date.now().toString().slice(-3),
    title: title,
    content: content,
    type: type,
    scope: scope,
    push: push,
    time: new Date().toLocaleString('zh-CN', {year:'numeric',month:'2-digit',day:'2-digit',hour:'2-digit',minute:'2-digit'}),
    status: '已发布',
    views: 0
  };
  _announcements.unshift(newAnn);
  showToast('📢 公告已发布至 ' + (scope==='all'?'全部设备':'指定范围'), 'success');
  openAnnouncementPublishModal();
}

function revokeAnnouncement(id) {
  if (!confirm('确定撤回该公告？')) return;
  var ann = _announcements.find(function(a){ return a.id === id; });
  if (ann) ann.status = '已撤回';
  showToast('公告 ' + id + ' 已撤回', 'info');
  openAnnouncementPublishModal();
}

