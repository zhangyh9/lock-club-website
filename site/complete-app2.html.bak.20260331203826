// ============================================================
// 【改进1】工单管理 - applyWorkorderSearch（关键词+类型+状态+优先级综合搜索）
// 理由：工单工具栏有搜索框和多个筛选下拉，但applyWorkorderSearch函数缺失
// 改进：根据关键词/类型/状态/优先级综合过滤，联动渲染工单表格+更新统计数字
// ============================================================
function applyWorkorderSearch() {
  var kwInput = document.getElementById('wo-search-input');
  var kw = kwInput ? kwInput.value.trim().toLowerCase() : '';
  var typeSel = document.getElementById('wo-type-filter');
  var typeFilter = typeSel ? typeSel.value : 'all';
  var statusSel = document.getElementById('wo-status-filter');
  var statusFilter = statusSel ? statusSel.value : 'all';
  var prioritySel = document.getElementById('wo-priority-filter');
  var priorityFilter = prioritySel ? prioritySel.value : 'all';
  var statusMap = {pending:'pending', processing:'processing', done:'done'};
  var typeMap = {complaint:'complaint', delivery:'delivery', invoice:'invoice', praise:'praise', repair:'repair', other:'other'};
  var filtered = _woList.filter(function(wo) {
    var matchKw = !kw
      || wo.id.toLowerCase().indexOf(kw) >= 0
      || (wo.customer && wo.customer.toLowerCase().indexOf(kw) >= 0)
      || (wo.room && wo.room.toLowerCase().indexOf(kw) >= 0)
      || (wo.desc && wo.desc.toLowerCase().indexOf(kw) >= 0)
      || (wo.phone && wo.phone.toLowerCase().indexOf(kw) >= 0);
    var matchType = typeFilter === 'all' || wo.type === typeMap[typeFilter];
    var matchStatus = statusFilter === 'all' || wo.status === statusMap[statusFilter];
    var matchPriority = priorityFilter === 'all' || wo.priority === priorityFilter;
    return matchKw && matchType && matchStatus && matchPriority;
  });
  var tbody = document.getElementById('workorder-table-body');
  if (!tbody) return;
  var rows = '';
  filtered.forEach(function(wo) {
    var isOverdue = wo.status !== 'done' && wo.sla && wo.sla !== '--' && new Date(wo.sla.replace('今天','2026-03-29')) < new Date();
    var statusBadge = wo.status === 'done' ? '<span class="tbadge green">已完成</span>'
      : wo.status === 'processing' ? '<span class="tbadge orange">处理中</span>'
      : '<span class="tbadge blue">待接受</span>';
    var actionBtn = wo.status === 'done'
      ? '<button class="action-btn small" onclick="openProcessWorkorderModal(' + _woList.indexOf(wo) + ')">查看</button>'
      : '<button class="action-btn small" onclick="openProcessWorkorderModal(' + _woList.indexOf(wo) + ')">处理</button>';
    var priorityColorMap = {urgent:'red',high:'orange',normal:'blue',low:'gray'};
    var priorityColor = priorityColorMap[wo.priority] || 'gray';
    rows += '<tr' + (isOverdue ? ' style="background:var(--red-bg);"' : '') + '>' +
      '<td style="font-size:11px;font-family:monospace;">' + wo.id + '</td>' +
      '<td>' + getWoTypeLabel(wo.type) + '</td>' +
      '<td>' + wo.room + '</td>' +
      '<td><div style="font-weight:600;">' + wo.customer + '</div><div style="font-size:10px;color:var(--text-muted);">' + wo.phone + '</div></td>' +
      '<td><span class="tbadge ' + priorityColor + '">' + getWoPriorityLabel(wo.priority) + '</span></td>' +
      '<td>' + statusBadge + '</td>' +
      '<td>' + (wo.assign || '--') + '</td>' +
      '<td style="font-size:11px;">' + wo.create + '</td>' +
      '<td style="font-size:11px;color:' + (isOverdue ? 'var(--red)' : 'var(--text-muted)') + ';">' + (wo.sla || '--') + (isOverdue ? ' ⚠️' : '') + '</td>' +
      '<td>' + actionBtn + '</td></tr>';
  });
  tbody.innerHTML = rows || '<tr><td colspan="10" style="text-align:center;padding:30px;color:var(--text-muted);">未找到匹配的服务工单</td></tr>';
  var totalEl = document.querySelector('#page-workorder .stat-card:nth-child(1) .stat-num');
  if (totalEl) totalEl.textContent = filtered.length;
  var pendingEl = document.querySelector('#page-workorder .stat-card:nth-child(2) .stat-num');
  if (pendingEl) pendingEl.textContent = filtered.filter(function(w){ return w.status === 'pending'; }).length;
  var processingEl = document.querySelector('#page-workorder .stat-card:nth-child(3) .stat-num');
  if (processingEl) processingEl.textContent = filtered.filter(function(w){ return w.status === 'processing'; }).length;
  var doneEl = document.querySelector('#page-workorder .stat-card:nth-child(4) .stat-num');
  if (doneEl) doneEl.textContent = filtered.filter(function(w){ return w.status === 'done'; }).length;
  showToast('🔍 找到 ' + filtered.length + ' 条工单', 'info');
}

