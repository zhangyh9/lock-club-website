  }).join('') + '<button class="action-btn small" onclick="clearLogUuidFilter()" style="padding:3px 8px;font-size:10px;">全部</button>';
})();
function filterLogByUuid(uuid, btn) {
  _logUuidFilter = uuid;
  document.querySelectorAll('#uuid-quick-chips .action-btn').forEach(function(b){ b.style.background='var(--bg)'; b.style.color='var(--text)'; b.style.fontWeight='normal'; });
  if(btn) { btn.style.background='var(--blue-bg)'; btn.style.color='var(--blue)'; btn.style.fontWeight='700'; }
  applyLogFilter && applyLogFilter();
}
function clearLogUuidFilter() {
  _logUuidFilter = null;
