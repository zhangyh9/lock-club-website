.report-kpi-card .trend.down { color: var(--red); }
.report-chart-placeholder { height: 200px; background: var(--bg); border-radius: 8px; display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 13px; position: relative; overflow: hidden; }
.report-chart-bars { display: flex; align-items: flex-end; gap: 8px; height: 160px; padding: 0 16px; }
