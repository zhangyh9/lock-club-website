/* v3 新增样式：诊断工具 */
.diag-card { border: 1px solid var(--border); border-radius: 8px; padding: 16px; background: var(--white); }
.diag-item { display: flex; align-items: center; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 13px; }
