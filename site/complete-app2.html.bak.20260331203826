    'device-detail':'device-detail','energy':'energy','workorder':'workorder',
    'history':'history','handover':'handover','blacklist':'blacklist'
  };
  if (menuMap[pageName]) {
    var el = document.querySelector('[onclick="showPage(\'' + menuMap[pageName] + '\')"]');
    if (el) el.classList.add('active');
  }
  var sidebar = document.getElementById('sidebar');
  if (sidebar) {
    sidebar.classList.remove('collapsed');
