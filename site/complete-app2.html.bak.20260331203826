// 【改进3】工单创建表单：照片上传 + 附件上传 + 提交处理
var woUploadedPhotos = [];
var woUploadedFiles = [];
function handleWoPhotoUpload(input) {
  if (!input.files) return;
  Array.from(input.files).forEach(function(file) {
    if (woUploadedPhotos.length >= 5) { showToast('最多上传5张照片', 'warn'); return; }
    var reader = new FileReader();
    reader.onload = function(e) {
      woUploadedPhotos.push(file.name);
      var div = document.createElement('div');
      div.style.cssText = 'position:relative;width:60px;height:60px;border-radius:8px;overflow:hidden;border:1px solid var(--border);';
      div.innerHTML = '<img src="' + e.target.result + '" style="width:100%;height:100%;object-fit:cover;">' +
        '<button onclick="removeWoPhoto(this,\'' + file.name + '\')" style="position:absolute;top:2px;right:2px;width:18px;height:18px;background:rgba(0,0,0,0.6);color:white;border:none;border-radius:50%;font-size:11px;cursor:pointer;line-height:18px;text-align:center;">✕</button>' +
        '<div style="position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.5);color:white;font-size:9px;text-align:center;padding:2px;">' + file.name.substring(0, 10) + '</div>';
      document.getElementById('wo-photo-list').appendChild(div);
    };
    reader.readAsDataURL(file);
  });
  input.value = '';
}
function removeWoPhoto(btn, name) {
  woUploadedPhotos = woUploadedPhotos.filter(function(n) { return n !== name; });
  btn.parentElement.remove();
}
function handleWoAttachUpload(input) {
  if (!input.files) return;
  Array.from(input.files).forEach(function(file) {
    woUploadedFiles.push(file.name);
    var div = document.createElement('div');
    div.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 10px;background:var(--bg);border-radius:6px;border:1px solid var(--border);';
    div.innerHTML = '<span style="font-size:14px;">📎</span><span style="flex:1;font-size:12px;">' + file.name + '</span>' +
      '<span style="font-size:11px;color:var(--text-muted);">' + (file.size / 1024).toFixed(0) + 'KB</span>' +
      '<button onclick="removeWoAttach(this,\'' + file.name + '\')" style="background:none;border:none;color:var(--red);cursor:pointer;font-size:14px;">✕</button>';
    document.getElementById('wo-attach-list').appendChild(div);
  });
  input.value = '';
}
function removeWoAttach(btn, name) {
  woUploadedFiles = woUploadedFiles.filter(function(n) { return n !== name; });
