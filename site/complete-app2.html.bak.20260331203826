      '<div style="display:flex;flex-direction:column;gap:4px;font-size:11px;">' +
        '<div style="display:flex;align-items:center;gap:4px;"><span>🚪</span><span style="color:var(--text-muted);">门锁：</span><span style="font-weight:500;" class="' + lockClass + '">' + r.lock + '</span></div>' +
        '<div style="display:flex;align-items:center;gap:4px;"><span>🔋</span><span style="color:var(--text-muted);">电量：</span><span style="font-weight:500;" class="' + battClass + '">' + r.battery + '%</span></div>' +
