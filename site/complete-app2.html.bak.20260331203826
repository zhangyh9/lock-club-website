    function openHKTaskAddModal() { showToast('清洁任务管理已转移至设备管理', 'info'); }
    function submitHKTask() { showToast('清洁任务管理已转移至设备管理', 'info'); }
    function openBulkAssignModal() {
      showToast('🔄 批量分配清洁任务...', 'info');
    }
    function exportHousekeepingReport() {
      showToast('📤 正在导出清洁报告...', 'info');
    }
