<script>
// 设备批量控制相关JS
var batchSelectedDevices = [];
var batchSelectedOp = null;

// 【修复T05】全局搜索功能缺失
// 【P76新增】全局搜索历史记录（最近10条）
var _globalSearchHistory = JSON.parse(localStorage.getItem('iot_search_history') || '[]');
function _saveGlobalSearchHistory(q) {
  if (!q || q.length < 2) return;
  _globalSearchHistory = _globalSearchHistory.filter(function(h){ return h !== q; });
  _globalSearchHistory.unshift(q);
  _globalSearchHistory = _globalSearchHistory.slice(0, 10);
  try { localStorage.setItem('iot_search_history', JSON.stringify(_globalSearchHistory)); } catch(e){}
}
function _renderGlobalSearchHistory() {
  if (_globalSearchHistory.length === 0) return '';
  return '<div style="padding:8px 12px 4px;font-size:11px;color:var(--text-muted);font-weight:600;border-bottom:1px solid var(--border);">最近搜索</div>' +
    _globalSearchHistory.map(function(h) {
      return '<div onclick="var inp=document.getElementById(\'global-search-overlay-input\');if(inp){inp.value=\'' + h.replace(/'/g, "\\'") + '\';performGlobalSearch(\'' + h.replace(/'/g, "\\'") + '\');}" style="padding:8px 16px;cursor:pointer;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--border);font-size:13px;color:var(--text);">' +
        '<span style="color:var(--text-muted);font-size:12px;">🕐</span><span>' + h + '</span></div>';
    }).join('') +
    '<div onclick="_globalSearchHistory=[];try{localStorage.removeItem(\'iot_search_history\');}catch(e){}var r=document.getElementById(\'global-search-results\');if(r)r.style.display=\'none\';" style="padding:8px 16px;cursor:pointer;font-size:12px;color:var(--text-muted);text-align:center;">清除历史</div>';
}
window.performGlobalSearch = function(q) {
  var results = document.getElementById('global-search-results');
  if (!results) return;
  // 【P76】显示搜索历史（输入框聚焦但未输入时）
  if (!q || q.length < 1) {
    results.innerHTML = _renderGlobalSearchHistory();
    results.style.display = 'block';
    return;
  }
  q = q.toLowerCase().trim();
  var data = [];
  // Search deviceData
  if (typeof deviceData !== 'undefined') {
    deviceData.forEach(function(d) {
      if ((d.num && d.num.toLowerCase().includes(q)) ||
          (d.uuid && d.uuid.toLowerCase().includes(q)) ||
          (d.type && d.type.toLowerCase().includes(q)) ||
          (d.guest && d.guest.toLowerCase().includes(q)) ||
          (d.phone && d.phone.toLowerCase().includes(q))) {
        data.push({type:'device', label:(d.num||'') + ' ' + (d.type||''), sub:(d.status||'') + (d.battery ? ' | ' + d.battery : ''), uuid:d.uuid});
      }
    });
  }
  // Search roomData
  if (typeof roomData !== 'undefined') {
    roomData.forEach(function(r) {
      if ((r.num && r.num.toLowerCase().includes(q)) ||
          (r.guest && r.guest.toLowerCase().includes(q)) ||
          (r.phone && r.phone.toLowerCase().includes(q))) {
        data.push({type:'room', label:'🏠 ' + r.num, sub:(r.status||'') + (r.guest ? ' | ' + r.guest : ''), num:r.num});
      }
    });
  }
  data = data.slice(0, 10);
  if (data.length === 0) {
    results.innerHTML = '<div style="padding:20px;text-align:center;color:var(--text-muted);font-size:13px;">未找到匹配结果</div>';
  } else {
    var html = '';
    data.forEach(function(item) {
      var click = item.type === 'device' ? "showPage('device-detail');setDeviceDetail('" + item.uuid + "')" :
                  item.type === 'room' ? "showPage('room-detail');setRoomDetail('" + item.num + "')" : '';
      html += '<div onclick="' + click + ';closeGlobalSearch()" style="padding:10px 16px;cursor:pointer;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;"><div><div style="font-size:13px;font-weight:600;">' + item.label + '</div><div style="font-size:11px;color:var(--text-muted);">' + item.sub + '</div></div><span style="font-size:11px;color:var(--blue);">' + (item.type==='device'?'📱':'🏠') + '</span></div>';
    });
    results.innerHTML = html;
  }
  results.style.display = 'block';
  // 【P76】搜索完成后保存到历史记录
  _saveGlobalSearchHistory(q);
};
window.closeGlobalSearch = function() {
  var bar = document.getElementById('global-search-bar');
  var results = document.getElementById('global-search-results');
  if (bar) bar.style.display = 'none';
  if (results) results.style.display = 'none';
};

var allDevicesForBatch = [
  {room:'301', uuid:'A84F1AF2', type:'领握LH-807', status:'online', battery:88},
  {room:'303', uuid:'C73D4CG4', type:'领握LH-807', status:'offline', battery:0},
  {room:'305', uuid:'D64E5DH5', type:'领握LH-807', status:'low', battery:28},
  {room:'201', uuid:'E75F6EI6', type:'领握LH-807', status:'online', battery:92},
  {room:'202', uuid:'F86G7FJ7', type:'领握LH-807', status:'online', battery:65},
  {room:'203', uuid:'G97H8GK8', type:'领握LH-807', status:'online', battery:45}
];

function openBatchDeviceControlModal() {
  batchSelectedDevices = [];
  batchSelectedOp = null;
  document.getElementById('bdc-device-list').innerHTML = '<div style="padding:6px 10px;background:white;border:1px solid var(--border);border-radius:6px;font-size:12px;color:var(--text-muted);">请从下方勾选设备</div>';
