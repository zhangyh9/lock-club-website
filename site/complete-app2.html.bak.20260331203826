function doBatchAssignWorkorder() {
  var sel = document.getElementById('wo-batch-ids');
  var handler = document.getElementById('wo-batch-handler') ? document.getElementById('wo-batch-handler').value : 'staff';
  if (!sel || sel.selectedOptions.length === 0) { showToast('请选择要分配的工单', 'error'); return; }
  var count = 0;
  var handlerLabels = {staff:'前厅员工', manager:'前厅经理', engineer:'工程部'};
  Array.from(sel.selectedOptions).forEach(function(opt) {
    var item = workorderSLAStore.find(function(w){ return w.id === parseInt(opt.value); });
    if (item) { item.handler = handler; item.status = 'processing'; count++; }
    // Also sync to main _woList
    var wo = _woList.find(function(x){ return x.desc === item.title || x.room === item.room; });
