  if (!type || !room || !content) {
    showToast('请填写工单类型、房间号和工单内容', 'error');
    return;
  }
  var photos = woUploadedPhotos.length > 0 ? woUploadedPhotos.join(', ') : '无';
  var files = woUploadedFiles.length > 0 ? woUploadedFiles.join(', ') : '无';
  var wo = {
    id: 'WO-' + new Date().getTime(),
    type: type,
    room: room,
    customer: document.getElementById('wo-customer') ? document.getElementById('wo-customer').value : '',
    content: content,
    status: 'pending',
    time: new Date().toLocaleString('zh-CN', {hour:'2-digit',minute:'2-digit'}),
