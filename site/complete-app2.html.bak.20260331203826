  var occValues = {'today':'82.5%','yesterday':'75.0%','thisweek':'78.3%','thismonth':'75.0%','lastmonth':'69.8%'};
  var revValues = {'today':'¥980','yesterday':'¥1,620','thisweek':'¥6,840','thismonth':'¥28,640','lastmonth':'¥25,120'};
  var occEl = document.getElementById('rpt-occupy');
  var revEl = document.getElementById('rpt-revenue');
  if (occEl) occEl.textContent = occValues[period] || '75.0%';
  if (revEl) revEl.textContent = revValues[period] || '¥28,640';
