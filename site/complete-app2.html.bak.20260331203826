}

function updateSlaRule(idx) {
  var duration = document.getElementById('sla-form-duration').value;
  var unit = document.getElementById('sla-form-unit').value;
  var action = document.getElementById('sla-form-action').value;
  var notify = document.getElementById('sla-form-notify').value.trim();
  var status = document.getElementById('sla-form-status').value;
  if (!duration || !notify) { showToast('请填写必填项', 'error'); return; }
  _slaRules[idx].时限 = parseInt(duration);
  _slaRules[idx].单位 = unit;
  _slaRules[idx].升级方式 = action;
  _slaRules[idx].通知人 = notify;
  _slaRules[idx].状态 = status;
  document.getElementById('modal-sla-form').remove();
  showToast('✅ SLA规则已更新', 'success');
  openSlaConfigModal();
}

function deleteSlaRule(idx) {
  if (!confirm('确定删除该SLA规则？')) return;
  _slaRules.splice(idx, 1);
  document.getElementById('modal-sla-form').remove();
  showToast('已删除SLA规则', 'info');
  openSlaConfigModal();
}

function saveSlaRules() {
  showToast('✅ SLA规则配置已保存（' + _slaRules.length + ' 条规则）', 'success');
}

