function cancelWorkorderById(woId) {
  if (!confirm('确定要作废工单 ' + woId + ' 吗？')) return;
  var wo = _woList.find(function(w){return w.id === woId || w.id === woId});
  if (!wo) { showToast('工单不存在', 'error'); return; }
  wo.status = 'cancelled';
  wo.assign = '--';
  showToast('工单 ' + woId + ' 已作废', 'success');
  renderWorkorderTable();
}
function reopenWorkorderById(woId) {
  var wo = _woList.find(function(w){return w.id === woId});
  if (!wo) { showToast('工单不存在', 'error'); return; }
  wo.status = 'pending';
  wo.assign = '未分配';
  showToast('工单 ' + woId + ' 已重新打开', 'success');
  renderWorkorderTable();
}
var _woSelectedIds = [];
function toggleWorkorderRow(cb, woId) {
  if (cb.checked) {
    if (_woSelectedIds.indexOf(woId) < 0) _woSelectedIds.push(woId);
  } else {
    _woSelectedIds = _woSelectedIds.filter(function(id){return id !== woId});
  }
  updateBatchWorkorderButtons();
}
function toggleAllWorkorderSelect(checked) {
  if (checked) {
    _woSelectedIds = _woList.filter(function(w){return w.status!=='done'&&w.status!=='cancelled'}).map(function(w){return w.id});
  } else {
    _woSelectedIds = [];
  }
  document.querySelectorAll('.wo-row-check').forEach(function(cb){ cb.checked = checked; });
  updateBatchWorkorderButtons();
}
function updateBatchWorkorderButtons() {
  var acceptBtn = document.getElementById('wo-batch-accept-btn');
  var closeBtn = document.getElementById('wo-batch-close-btn');
  var countEl = document.getElementById('wo-batch-count');
  var count = _woSelectedIds.length;
  if (countEl) countEl.textContent = count;
  if (acceptBtn) acceptBtn.style.display = count > 0 ? 'inline-flex' : 'none';
  if (closeBtn) closeBtn.style.display = count > 0 ? 'inline-flex' : 'none';
}
function batchAcceptWorkorders() {
  if (_woSelectedIds.length === 0) { showToast('请先选择要接受的工单', 'error'); return; }
  var count = 0;
  _woSelectedIds.forEach(function(id) {
    var wo = _woList.find(function(w){return w.id === id});
    if (wo && wo.status === 'pending') { wo.status = 'processing'; wo.assign = '当前员工'; count++; }
  });
  showToast('成功接受 ' + count + ' 条工单', 'success');
  _woSelectedIds = [];
  renderWorkorderTable();
}
function batchCloseWorkorders() {
  if (_woSelectedIds.length === 0) { showToast('请先选择要关闭的工单', 'error'); return; }
  if (!confirm('确定要关闭选中的 ' + _woSelectedIds.length + ' 条工单吗？')) return;
  var count = 0;
  _woSelectedIds.forEach(function(id) {
    var wo = _woList.find(function(w){return w.id === id});
    if (wo && wo.status !== 'done') { wo.status = 'cancelled'; count++; }
  });
  showToast('已关闭 ' + count + ' 条工单', 'success');
  _woSelectedIds = [];
  renderWorkorderTable();
}

