      '<div style="display:flex;align-items:center;gap:10px;">' +
      '<div style="font-size:18px;">🏢</div>' +
      '<div style="flex:1;">' +
      '<div style="font-size:14px;font-weight:700;">' + b.name + ' <span style="font-size:11px;color:var(--text-muted);">(' + b.code + ')</span></div>' +
      '<div style="font-size:12px;color:var(--text-muted);">' + b.floors + '层 · ' + b.rooms + '间 · ' + b.address + '</div></div>' +
      statusBadge +
      '<button class="action-btn small" onclick="openBuildingFormModal(\'edit\',\'' + b.id + '\')" style="padding:4px 8px;">编辑</button></div></div>';
  }).join('');
  el.innerHTML = html;
}
function openBuildingFormModal(mode, id) {
  document.getElementById('bldf-id').value = id || '';
  document.getElementById('bldf-name').value = '';
  document.getElementById('bldf-code').value = '';
  document.getElementById('bldf-floors').value = '3';
  document.getElementById('bldf-rooms').value = '16';
  document.getElementById('bldf-status').value = 'active';
  document.getElementById('bldf-address').value = '';
  document.getElementById('bldf-title').textContent = mode === 'edit' ? '✏️ 编辑楼栋' : '➕ 新增楼栋';
  if (mode === 'edit' && id) {
    var b = buildingStore.find(function(b) { return b.id === id; });
    if (b) {
      document.getElementById('bldf-name').value = b.name;
      document.getElementById('bldf-code').value = b.code;
      document.getElementById('bldf-floors').value = b.floors;
      document.getElementById('bldf-rooms').value = b.rooms;
      document.getElementById('bldf-status').value = b.status;
      document.getElementById('bldf-address').value = b.address;
    }
  }
  openModal('building-form-v2');
}

