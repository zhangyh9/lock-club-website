      (r.status === 'in' ? '<div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--border);font-size:10px;color:var(--text-muted);"><span class="room-guest-name" style="font-weight:600;color:var(--text);">' + r.guest + '</span> · ' + r.phone + '<br>入住：' + r.checkin + ' → 退：' + r.checkout + '</div>' : '') +
