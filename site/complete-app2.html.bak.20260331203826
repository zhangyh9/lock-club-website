      '<td style="font-weight:600;">' + b.name + '</td>' +
      '<td style="font-size:12px;color:var(--text-muted);">' + b.phone + '</td>' +
      '<td style="font-size:11px;font-family:monospace;color:var(--text-muted);">' + b.idCard + '</td>' +
