function updateBatchUpgradeSummary() {
  var checks = document.querySelectorAll('.bfu-check:checked');
  var count = checks ? checks.length : 0;
  var countEl = document.getElementById('bfu-count');
  if (countEl) countEl.textContent = count;
}

function selectAllNeedUpgrade() {
  document.querySelectorAll('.bfu-check').forEach(function(cb) { cb.checked = true; });
  updateBatchUpgradeSummary();
}

function clearAllUpgradeSelect() {
  document.querySelectorAll('.bfu-check').forEach(function(cb) { cb.checked = false; });
  updateBatchUpgradeSummary();
}

function startBatchFirmwareUpgrade() {
  var checks = document.querySelectorAll('.bfu-check:checked');
  if (!checks || checks.length === 0) { showToast('请至少选择一台设备', 'warning'); return; }
  var progressWrap = document.getElementById('bfu-progress-wrap');
  var progressBar = document.getElementById('bfu-progress-bar');
  var progressPct = document.getElementById('bfu-progress-pct');
  var progressLabel = document.getElementById('bfu-progress-label');
  var startBtn = document.getElementById('bfu-start-btn');
  if (progressWrap) progressWrap.style.display = 'block';
  if (startBtn) { startBtn.disabled = true; startBtn.textContent = '升级中...'; }
  var total = checks.length;
  var done = 0;
  var interval = setInterval(function() {
    done++;
    var pct = Math.round((done / total) * 100);
    if (progressBar) progressBar.style.width = pct + '%';
    if (progressPct) progressPct.textContent = pct + '%';
    if (progressLabel) progressLabel.textContent = '正在升级第 ' + done + '/' + total + ' 台设备...';
    if (done >= total) {
      clearInterval(interval);
      if (progressLabel) progressLabel.textContent = '✅ 全部升级完成！';
      if (startBtn) { startBtn.disabled = false; startBtn.textContent = '🚀 开始批量升级'; }
      showToast('✅ ' + total + ' 台设备固件批量升级完成！', 'success');
    }
  }, 600);
}

