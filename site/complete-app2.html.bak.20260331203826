function submitBuildingForm() {
  var name = document.getElementById('bldf-name').value.trim();
  var code = document.getElementById('bldf-code').value.trim().toUpperCase();
  var floors = parseInt(document.getElementById('bldf-floors').value) || 3;
  var rooms = parseInt(document.getElementById('bldf-rooms').value) || 16;
  var status = document.getElementById('bldf-status').value;
  var address = document.getElementById('bldf-address').value.trim();
  if (!name || !code) {
    showToast('请填写楼栋名称和编号', 'error');
    return;
  }
  var id = document.getElementById('bldf-id').value;
  if (id) {
    // 编辑模式
    var idx = buildingStore.findIndex(function(b) { return b.id === id; });
    if (idx !== -1) {
      buildingStore[idx] = {id:id, name:name, code:code, floors:floors, rooms:rooms, status:status, address:address};
      showToast('✅ 楼栋「' + name + '」已更新', 'success');
    }
  } else {
    // 新增模式
    var newId = 'bld_' + Date.now();
    buildingStore.push({id:newId, name:name, code:code, floors:floors, rooms:rooms, status:status, address:address});
    showToast('✅ 新楼栋「' + name + '」已创建（共' + buildingStore.length + '栋）', 'success');
  }
  closeModal('building-form-v2');
  renderBuildingList();
}
