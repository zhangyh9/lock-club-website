function goDevicePage(dir) {
  var filtered = getFilteredDeviceList();
  var totalPages = Math.ceil(filtered.length / _devicePageSize) || 1;
  if (dir === 'prev' && _devicePage > 1) _devicePage--;
  if (dir === 'next' && _devicePage < totalPages) _devicePage++;
  renderDeviceFilteredTable();
}

function getFilteredDeviceList() {
  return deviceData.filter(function(d) {
    var groupMap = {'main':['301','302','303','304','305','306'],'east':['201','202','203','204','205','206'],'vip':['101','102','103','104']};
    var groupMatch = _deviceGroupFilter === 'all' || (groupMap[_deviceGroupFilter] && groupMap[_deviceGroupFilter].indexOf(d.room) >= 0) || (_deviceGroupFilter === 'lowbat' && d.battery < IOT_CONST.BATTERY_CRITICAL);
    var statusMap = {'online':d.status==='在线','offline':d.status==='离线','lowbattery':d.status.indexOf('低电量')>=0,'all':true};
    var statusMatch = statusMap[_deviceStatusFilter] !== undefined ? statusMap[_deviceStatusFilter] : true;
    var kwMatch = !_deviceSearchKw || d.room.toLowerCase().indexOf(_deviceSearchKw) >= 0 || d.uuid.toLowerCase().indexOf(_deviceSearchKw) >= 0 || d.model.toLowerCase().indexOf(_deviceSearchKw) >= 0;
    var batMatch = !_deviceBatteryFilter || (_deviceBatteryFilter === 'high' && d.battery >= IOT_CONST.BATTERY_HIGH) || (_deviceBatteryFilter === 'mid' && d.battery >= IOT_CONST.BATTERY_LOW && d.battery < IOT_CONST.BATTERY_HIGH) || (_deviceBatteryFilter === 'low' && d.battery >= IOT_CONST.BATTERY_CRITICAL && d.battery < IOT_CONST.BATTERY_LOW) || (_deviceBatteryFilter === 'crit' && d.battery < IOT_CONST.BATTERY_CRITICAL);
    // T18: signal filter (假设 deviceData 有 signal 字段，默认强信号)
    var sig = d.signal || -50;
    var sigMatch = !_deviceSignalFilter || (_deviceSignalFilter === 'excellent' && sig > -50) || (_deviceSignalFilter === 'good' && sig >= -70 && sig <= -50) || (_deviceSignalFilter === 'weak' && sig >= -90 && sig < -70) || (_deviceSignalFilter === 'poor' && sig < -90);
    return groupMatch && statusMatch && kwMatch && batMatch && sigMatch;
  });
}

function renderDeviceFilteredTable() {
  var filtered = getFilteredDeviceList();
  var tbody = document.getElementById('device-table-body');
  var infoEl = document.getElementById('device-pagination-info');
  var prevBtn = document.getElementById('device-page-prev');
  var nextBtn = document.getElementById('device-page-next');
  if (!tbody) return;
  var totalPages = Math.ceil(filtered.length / _devicePageSize) || 1;
  var start = (_devicePage - 1) * _devicePageSize;
  var pageData = filtered.slice(start, start + _devicePageSize);
  var rows = '';
  if (pageData.length === 0) {
    rows = '<tr><td colspan="8" style="text-align:center;padding:30px;color:var(--text-muted);">暂无设备数据</td></tr>';
  } else {
    pageData.forEach(function(d) {
      var batteryColor = d.battery > 60 ? 'var(--green)' : d.battery > 20 ? 'var(--orange)' : 'var(--red)';
      // 【P99修复】使用常量BATTERY_GOOD=60/BATTERY_CRITICAL=20替换电池颜色魔法数字
      var batteryBg = d.battery > IOT_CONST.BATTERY_GOOD ? 'var(--green-bg)' : d.battery > IOT_CONST.BATTERY_CRITICAL ? 'var(--orange-bg)' : 'var(--red-bg)';
      var statusColor = d.status === '在线' ? 'var(--green)' : d.status === '离线' ? 'var(--red)' : 'var(--text-muted)';
      var statusBg = d.status === '在线' ? 'var(--green-bg)' : d.status === '离线' ? 'var(--red-bg)' : 'var(--bg)';
      // 【改进2新增】UUID独立列（对照原系统截图）
      rows += '<tr>' +
        '<td><div style="font-size:12px;font-weight:600;">' + d.room + '</div></td>' +
        '<td><div style="font-size:11px;font-weight:600;">' + d.model + '</div></td>' +
        '<td><div style="font-size:10px;color:var(--text-muted);font-family:monospace;">' + d.uuid + '</div></td>' +
        '<td><span style="padding:2px 8px;background:' + statusBg + ';color:' + statusColor + ';border-radius:10px;font-size:11px;font-weight:600;">' + d.status + '</span></td>' +
        '<td><span style="padding:2px 8px;background:' + batteryBg + ';color:' + batteryColor + ';border-radius:10px;font-size:11px;font-weight:600;">🔋 ' + d.battery + '%</span></td>' +
        '<td style="font-size:12px;">' + d.signal + '</td>' +
        '<td style="font-size:11px;color:var(--text-muted);">' + d.lastSync + '</td>' +
        '<td><div style="display:flex;gap:4px;flex-wrap:nowrap;">' +
          '<button class="action-btn small" onclick="navigateToDeviceDetail(\'' + d.uuid + '\')" style="padding:3px 8px;font-size:11px;">👁️ 详情</button>' +
          '<button class="action-btn small" onclick="openDeviceEditModal(\'' + d.uuid + '\')" style="padding:3px 8px;font-size:11px;">✏️ 编辑</button>' +
          '<button class="action-btn small" onclick="openDeviceDiagnosticV2Enhanced(\'' + d.room + '\')" style="padding:3px 8px;font-size:11px;">🔍 诊断</button>' +
          '<button class="action-btn small red" onclick="deleteDeviceConfirm(\'' + d.uuid + '\')" style="padding:3px 8px;font-size:11px;">🗑️</button></div></td>' +
      '</tr>';
    });
  }
  tbody.innerHTML = rows;
  if (infoEl) infoEl.textContent = '第 ' + _devicePage + ' / ' + totalPages + ' 页，共 ' + filtered.length + ' 条';
  if (prevBtn) prevBtn.disabled = _devicePage <= 1;
  if (nextBtn) nextBtn.disabled = _devicePage >= totalPages;
}

/**
 * @description 诊断单个设备（P98+JSDoc补充）
 * @param {string} uuid - 设备UUID
 * @returns {void}
 */
function diagnoseDevice(uuid) {
  var d = deviceData.find(function(x){ return x.uuid === uuid; });
  if (!d) { showToast('未找到设备', 'error'); return; }
  showToast('🛠️ 正在诊断设备 ' + d.room + '...', 'info');
  setTimeout(function() {
    // 【P99修复】使用全局常量BATTERY_THRESHOLD_LOW=BATTERY_CRITICAL=20
    var DIAGNOSTIC_SCORE_MIN = 70;
    var DIAGNOSTIC_SCORE_RANGE = 30;
    var score = Math.floor(DIAGNOSTIC_SCORE_MIN + Math.random() * DIAGNOSTIC_SCORE_RANGE);
    var issues = [];
    if (d.battery < IOT_CONST.BATTERY_CRITICAL) issues.push('电池电量低');
    if (d.signal === '弱') issues.push('信号强度弱');
    var status = issues.length === 0 ? '✅ 健康' : '⚠️ 需关注';
    showToast('🔍 ' + d.room + ' 诊断完成：' + status + '（评分 ' + score + '分）', score >= 80 ? 'success' : 'warning');
  }, 1000);
}

