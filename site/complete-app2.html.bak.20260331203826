      '<td>' + statusBadge + '</td>' +
      '<td style="white-space:nowrap;">' + actionBtn + '</td></tr>';
  }).join('');
  tbody.innerHTML = rows || '<tr><td colspan="9" style="text-align:center;padding:30px;color:var(--text-muted);">暂无符合条件的记录</td></tr>';
