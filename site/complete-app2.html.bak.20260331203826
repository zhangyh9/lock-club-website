  var type = document.getElementById('wo-create-type') ? document.getElementById('wo-create-type').value : '';
  var priority = document.getElementById('wo-create-priority') ? document.getElementById('wo-create-priority').value : 'normal';
  var room = document.getElementById('wo-create-room') ? document.getElementById('wo-create-room').value : '';
  var handler = document.getElementById('wo-create-handler') ? document.getElementById('wo-create-handler').value : 'staff';
  var desc = document.getElementById('wo-create-desc') ? document.getElementById('wo-create-desc').value.trim() : '';
  if (!title) { showToast('请填写工单标题', 'error'); return; }
  if (!type) { showToast('请选择工单类型', 'error'); return; }
  var typeLabels = {complaint:'🔴 客户投诉', delivery:'📦 送物服务', invoice:'📄 发票需求', praise:'⭐ 点评表扬', repair:'🔧 设备报修', other:'📋 其他'};
  var now = new Date();
  var newItem = {
    id: workorderSLAStore.length + 1,
    title: title,
    type: type,
    status: 'pending',
    priority: priority,
    room: room,
    handler: handler,
    createTime: now.toISOString().slice(0,16).replace('T',' '),
    desc: desc
  };
  var slaMap = {complaint:30, delivery:20, invoice:120, praise:60, repair:60, other:120};
  newItem.slaMinutes = slaMap[type] || 60;
  workorderSLAStore.unshift(newItem);
  // Also add to main _woList for unified rendering
  var handlerLabels = {staff:'前厅员工', manager:'前厅经理', engineer:'工程部', finance:'财务部'};
  _woList.unshift({
    id: 'WO' + new Date().toISOString().slice(0,10).replace(/-/g,'') + String(_woList.length + 1).padStart(2,'0'),
    type: type,
    room: room,
    customer: '客户',
    phone: '--',
    desc: title,
    priority: priority,
    status: 'pending',
    assign: handlerLabels[handler] || handler,
