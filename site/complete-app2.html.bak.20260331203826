        '<button class="modal-btn secondary" onclick="closeModal(\'hk-delete\')">取消</button>' +
        '<button class="modal-btn" onclick="confirmHKTaskDelete(\'' + room + '\')" class="btn-red" style=">🗑️ 确认删除</button></div></div></div>';
      document.body.insertAdjacentHTML('beforeend', html);
    }
    function confirmHKTaskDelete(room) {
      closeModal('hk-delete');
      showToast('🗑️ 房间 ' + room + ' 清洁任务已删除', 'success');
    }
    function openHousekeepingTaskModal() {
