// 【v4-第X轮-改进1】renderWorkorderTable修复：支持Tab状态过滤+使用buildWorkorderRowHtml完整渲染
function renderWorkorderTable() {
  var tbody = document.getElementById('workorder-table-body');
  if (!tbody) return;
  var tab = _woCurrentTab || 'all';
  var filtered = tab === 'all' ? _woList : _woList.filter(function(wo) {
    if (tab === 'overdue') return wo.status !== 'done' && wo.sla && wo.sla !== '--' && new Date(wo.sla.replace('今天','2026-03-29')) < new Date();
    return wo.status === tab;
  });
  if (filtered.length === 0) {
    tbody.innerHTML = '<tr><td colspan="10" style="text-align:center;padding:40px;color:var(--text-muted);font-size:13px;">暂无工单数据</td></tr>';
    return;
  }
  var rows = '';
  filtered.forEach(function(wo, i) {
    rows += buildWorkorderRowHtml(wo, _woList.indexOf(wo));
  });
  tbody.innerHTML = rows;
  // 更新Tab统计数字
  var tabMap = {all: _woList.length, pending: _woList.filter(function(w){return w.status==='pending'}).length, processing: _woList.filter(function(w){return w.status==='processing'}).length, done: _woList.filter(function(w){return w.status==='done'}).length};
  var labels = ['全部 ' + (tabMap.all || 0), '待接受 ' + (tabMap.pending || 0), '处理中 ' + (tabMap.processing || 0), '已完成 ' + (tabMap.done || 0)];
  var tabs = ['all','pending','processing','done'];
  document.querySelectorAll('#page-workorder .card-tabs .card-tab').forEach(function(el, i) {
    if (tabs[i]) el.textContent = labels[i] || '';
    if (tabs[i] === tab) {
      el.classList.add('active');
      el.style.background = 'var(--blue)';
      el.style.color = 'white';
    } else {
      el.classList.remove('active');
      el.style.background = '';
      el.style.color = '';
    }
  });
}

