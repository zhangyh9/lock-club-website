  var el = document.getElementById('building-list-container');
  if (!el) return;
  var html = buildingStore.map(function(b) {
    var statusBadge = b.status === 'active' ? '<span style="padding:2px 8px;background:var(--green-bg);color:var(--green);border-radius:10px;font-size:11px;">✅ 启用</span>' : '<span style="padding:2px 8px;background:var(--red-bg);color:var(--red);border-radius:10px;font-size:11px;">❌ 停用</span>';
