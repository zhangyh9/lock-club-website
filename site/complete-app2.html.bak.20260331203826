      var type=document.getElementById('escalation-new-type').value;
      var time=parseInt(document.getElementById('escalation-new-time').value);
      var to=document.getElementById('escalation-new-to').value;
      var notify=document.getElementById('escalation-new-notify').value;
      var typeLabels={complaint:'🔴 客户投诉',repair:'🔧 设备报修',delivery:'📦 送物服务',invoice:'📄 发票需求',other:'📋 其他'};
      var toLabels={supervisor:'客房主管',manager:'前厅经理',admin:'管理员',staff:'前厅员工'};
      var timeLabels={15:'15分钟',30:'30分钟',60:'1小时',120:'2小时',240:'4小时'};
      escalationRules.push({type:type,typeLabel:typeLabels[type],time:time,timeLabel:timeLabels[time],to:to,toLabel:toLabels[to],notify:notify});
      renderEscalationRulesList();
      showToast('规则已添加：'+typeLabels[type]+' 超时'+timeLabels[time]+'升级','success');
    }
    function saveEscalationRules(){closeModal('wo-escalation-rules');showToast('✅ 升级规则配置已保存！共'+escalationRules.length+'条规则','success');}
    function toggleEscalationGlobal(){
      var cb=document.getElementById('escalation-global-enabled');
      cb.checked=!cb.checked;
      var slider=document.getElementById('escalation-global-slider');
      var knob=document.getElementById('escalation-global-knob');
      if(cb.checked){slider.style.background='var(--green)';knob.style.right='2px';knob.style.left='auto';}
      else{slider.style.background='#ccc';knob.style.left='2px';knob.style.right='auto';}
