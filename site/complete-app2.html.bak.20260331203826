      var compareData = {month:{this:'本月',last:'上月',thisVal:data.thisMonth,lastVal:data.lastMonth},week:{this:'本周',last:'上周',thisVal:(data.thisMonth/4).toFixed(1),lastVal:(data.lastMonth/4).toFixed(1)},today:{this:'今日',last:'昨日',thisVal:data.today,lastVal:data.yesterday}};
      var c = compareData[period];
      var change = ((c.thisVal - c.lastVal) / c.lastVal * 100).toFixed(1);
      var thisEl = document.getElementById('ec-this-month');
      if (thisEl) thisEl.parentElement.querySelector('div:first-child').textContent = '🏠 ' + c.this;
