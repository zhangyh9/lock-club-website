      {time:'2026-03-25 16:20:33', type:'config', typeLabel:'⚙️ 参数配置', operator:'王工(工程师)', detail:'修改门锁灵敏度等级：3级', result:'成功'},
      {time:'2026-03-24 11:05:00', type:'upgrade', typeLabel:'📦 固件升级', operator:'系统', detail:'OTA升级 v2.2.0 → v2.3.1', result:'成功'},
      {time:'2026-03-23 08:00:15', type:'sync', typeLabel:'🔄 设备同步', operator:'系统', detail:'每日定时同步', result:'成功'},
      {time:'2026-03-22 15:40:22', type:'unlock', typeLabel:'🔓 远程开锁', operator:'周敏(前台)', detail:'后台手动远程开锁', result:'成功'},
    ];
    function renderDevOplogTable() {
      var tbody = document.getElementById('dev-oplog-body');
      if (!tbody) return;
      var typeFilter = document.getElementById('dev-oplog-type-filter') ? document.getElementById('dev-oplog-type-filter').value : 'all';
      var filtered = typeFilter === 'all' ? devOpLogData : devOpLogData.filter(function(d) { return d.type === typeFilter; });
      var html = '';
      filtered.forEach(function(d) {
        var resultColor = d.result === '成功' ? 'var(--green)' : 'var(--red)';
        var resultBg = d.result === '成功' ? 'var(--green-bg)' : 'var(--red-bg)';
        html += '<tr style="border-bottom:1px solid var(--border);">' +
          '<td style="padding:8px 12px;font-size:11px;color:var(--text-muted);">' + d.time + '</td>' +
          '<td style="padding:8px 12px;"><span style="font-size:11px;font-weight:600;">' + d.typeLabel + '</span></td>' +
          '<td style="padding:8px 12px;font-size:11px;">' + d.operator + '</td>' +
          '<td style="padding:8px 12px;font-size:11px;color:var(--text-light);">' + d.detail + '</td>' +
          '<td style="padding:8px 12px;"><span style="font-size:10px;padding:2px 8px;background:' + resultBg + ';color:' + resultColor + ';border-radius:8px;font-weight:600;">' + d.result + '</span></td>' +
          '</tr>';
      });
      tbody.innerHTML = html || '<tr><td colspan="5" style="padding:20px;text-align:center;color:var(--text-muted);font-size:12px;">暂无操作记录</td></tr>';
      var countEl = document.getElementById('dev-oplog-count');
      if (countEl) countEl.textContent = '共 ' + filtered.length + ' 条';
    }
    function exportDevOpLog() {
      var rows = document.querySelectorAll('#dev-oplog-body tr');
      var csv = '\uFEFF时间,操作类型,操作人,详情,结果\n';
      rows.forEach(function(row) {
        if (row.style.display !== 'none') {
          var tds = row.querySelectorAll('td');
          if (tds.length >= 5) {
            csv += '"' + tds[0].textContent + '","' + tds[1].textContent.trim() + '","' + tds[2].textContent + '","' + tds[3].textContent + '","' + tds[4].textContent.trim() + '"\n';
          }
        }
      });
      var blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
      a.download = '设备操作日志_' + new Date().toISOString().slice(0,10) + '.csv';
      a.click(); URL.revokeObjectURL(a.href);
      showToast('设备操作日志已导出！', 'success');
    }
    </script>
