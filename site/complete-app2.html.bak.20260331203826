}

function clearBatchSelection() {
  batchSelectedDevices = [];
  renderBatchDeviceList();
}

function renderBatchDeviceList() {
  var list = document.getElementById('bdc-device-list');
  if (batchSelectedDevices.length === 0) {
    list.innerHTML = '<div style="padding:6px 10px;background:white;border:1px solid var(--border);border-radius:6px;font-size:12px;color:var(--text-muted);">请从下方勾选设备</div>';
  } else {
    var html = allDevicesForBatch.map(function(d){
      var selected = batchSelectedDevices.indexOf(d.uuid) >= 0;
      var statusColor = d.status === 'online' ? 'var(--green)' : d.status === 'low' ? 'var(--orange)' : 'var(--red)';
      var bg = selected ? 'var(--blue-bg)' : 'white';
      var border = selected ? '2px solid var(--blue)' : '1px solid var(--border)';
      return '<div onclick="toggleBatchDevice(\''+d.uuid+'\')" style="padding:6px 10px;background:'+bg+';border:'+border+';border-radius:6px;font-size:12px;cursor:pointer;display:flex;align-items:center;gap:6px;">' +
        '<input type="checkbox" '+(selected?'checked':'')+' onclick="event.stopPropagation();toggleBatchDevice(\''+d.uuid+'\')" style="accent-color:var(--blue);">' +
        '<span style="font-weight:600;">'+d.room+'</span>' +
        '<span style="font-size:11px;color:var(--text-muted);">'+d.type+'</span>' +
        '<span style="width:6px;height:6px;border-radius:50%;background:'+statusColor+';flex-shrink:0;"></span>' +
        '<span style="font-size:11px;color:'+statusColor+';">'+(d.status==='online'?'在线':d.status==='low'?'低电量':'离线')+'</span>' +
        '<span style="font-size:11px;color:var(--text-muted);">'+d.battery+'%</span></div>';
    }).join('');
    list.innerHTML = html;
  }
  document.getElementById('bdc-selected-count').textContent = batchSelectedDevices.length;
  updateBatchConfirmArea();
}

function toggleBatchDevice(uuid) {
  var idx = batchSelectedDevices.indexOf(uuid);
  if (idx >= 0) batchSelectedDevices.splice(idx, 1);
  else batchSelectedDevices.push(uuid);
  renderBatchDeviceList();
}

function selectBatchOp(el, op) {
  batchSelectedOp = op;
  document.querySelectorAll('.bdc-op-card').forEach(function(c){ c.style.borderColor = 'var(--border)'; c.style.background = 'white'; });
  el.style.borderColor = 'var(--blue)';
  el.style.background = 'var(--blue-bg)';
  updateBatchConfirmArea();
}

function updateBatchConfirmArea() {
  var area = document.getElementById('bdc-confirm-area');
  if (batchSelectedDevices.length > 0 && batchSelectedOp) {
    area.style.display = 'block';
    document.getElementById('bdc-confirm-count').textContent = batchSelectedDevices.length;
    var opNames = {unlock:'批量开锁', sync:'批量同步', power:'通断电控制', restart:'批量重启', battery:'换电池提醒', freeze:'冻结权限'};
    document.getElementById('bdc-confirm-op').textContent = opNames[batchSelectedOp] || batchSelectedOp;
  } else {
    area.style.display = 'none';
  }
  toggleBatchConfirm();
}

function toggleBatchConfirm() {
  var checked = document.getElementById('bdc-confirm-check').checked;
  var btn = document.getElementById('bdc-execute-btn');
  if (checked && batchSelectedDevices.length > 0 && batchSelectedOp) {
    btn.disabled = false;
    btn.style.opacity = '1';
    btn.style.cursor = 'pointer';
  } else {
    btn.disabled = true;
    btn.style.opacity = '0.5';
    btn.style.cursor = 'not-allowed';
  }
}

function executeBatchControl() {
  var opNames = {unlock:'批量开锁', sync:'批量同步', power:'通断电控制', restart:'批量重启', battery:'换电池提醒', freeze:'冻结权限'};
  closeModal('modal-batch-device-control');
  showToast('⚡ 正在对 ' + batchSelectedDevices.length + ' 台设备执行「' + opNames[batchSelectedOp] + '」操作...', 'info');
  setTimeout(function(){
    var success = Math.floor(batchSelectedDevices.length * 0.9);
    showToast('✅ ' + opNames[batchSelectedOp] + '完成：成功 ' + success + ' 台，失败 ' + (batchSelectedDevices.length - success) + ' 台', success === batchSelectedDevices.length ? 'success' : 'warning');
  }, 2500);
}
</script>
