    var actionBtn = b.status === 'released'
      ? '<button class="action-btn small" onclick="openBlacklistDetail(\'' + b.id + '\')" style="padding:3px 8px;font-size:11px;">👁️ 查看</button>'
      : '<button class="action-btn small" onclick="openBlacklistDetail(\'' + b.id + '\')" style="padding:3px 8px;font-size:11px;">👁️ 查看</button>' +
        '<button class="action-btn small" onclick="releaseBlacklist(\'' + b.id + '\')" style="padding:3px 8px;font-size:11px;background:var(--green-bg);color:var(--green);border-color:var(--green);">🔓 解除</button>';
