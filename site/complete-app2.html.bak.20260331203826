// 业务逻辑：切换看板Tab视图，切换对应内容面板，更新按钮激活状态
// ============================================================
window.switchDashboardView = function(view) {
  // Tab button states
  var tabs = [
    {id: 'dvtab-overview', view: 'overview', label: '实时概览'},
    {id: 'dvtab-device', view: 'device', label: '设备状态'},
    {id: 'dvtab-alert', view: 'alert', label: '告警统计'},
    {id: 'dvtab-energy', view: 'energy', label: '能耗概览'}
  ];
  
  // Update tab button styles via CSS class
  tabs.forEach(function(t) {
    var btn = document.getElementById(t.id);
    if (btn) {
      if (t.view === view) {
        btn.classList.add('active');
      } else {
        btn.classList.remove('active');
      }
    }
  });
  
  // Show/hide content panels
  var panels = ['dv-panel-overview', 'dv-panel-device', 'dv-panel-alert', 'dv-panel-energy'];
  var panelMap = {
    'overview': 'dv-panel-overview',
    'device': 'dv-panel-device',
    'alert': 'dv-panel-alert',
    'energy': 'dv-panel-energy'
  };
  
  var targetPanel = panelMap[view];
  panels.forEach(function(pid) {
    var panel = document.getElementById(pid);
    if (panel) {
      panel.style.display = pid === targetPanel ? 'block' : 'none';
    }
  });
};

