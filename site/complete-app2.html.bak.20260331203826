    '💡 勾选员工后将立即分配该角色，取消勾选将移除角色。</div>' +
    '</div>' +
    '<div class="modal-footer"><button class="modal-btn secondary" onclick="document.getElementById(\'modal-role-assign\').remove()">关闭</button>' +
    '<button class="modal-btn primary" onclick="confirmRoleAssignment()">💾 确认分配</button></div></div></div>';
  var old = document.getElementById('modal-role-assign');
  if (old) old.remove();
  document.body.insertAdjacentHTML('beforeend', html2);
  renderRoleAssignList();
}

function renderRoleAssignList() {
  var list = document.getElementById('ras-staff-list');
  if (!list) return;
  var search = document.getElementById('ras-search') ? document.getElementById('ras-search').value.toLowerCase() : '';
  var roleFilter = document.getElementById('ras-role-filter') ? document.getElementById('ras-role-filter').value : 'all';
  var staff = staffForRoleAssign.filter(function(s) {
    if (search && s.name.toLowerCase().indexOf(search) === -1) return false;
    if (roleFilter !== 'all' && s.role !== roleFilter) return false;
    return true;
  });
  var html3 = '';
  var checkedCount = 0;
  staffForRoleAssign.forEach(function(s, globalIdx) {
    var match = true;
    if (search && s.name.toLowerCase().indexOf(search) === -1) match = false;
    if (roleFilter !== 'all' && s.role !== roleFilter) match = false;
    if (!match) return;
    if (s.checked) checkedCount++;
    html3 += '<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:' + (s.checked ? 'var(--blue-bg)' : 'white') + ';border:1px solid ' + (s.checked ? 'var(--blue)' : 'var(--border)') + ';border-radius:8px;cursor:pointer;" onclick="toggleRoleAssignItem(this, ' + globalIdx + ')">' +
      '<input type="checkbox" ' + (s.checked ? 'checked' : '') + ' style="accent-color:var(--blue);width:16px;height:16px;" onclick="event.stopPropagation();">' +
      '<div style="flex:1;"><div style="font-weight:600;font-size:13px;">' + s.name + '</div><div style="font-size:11px;color:var(--text-muted);">' + s.role + '</div></div>' +
      '<span class="tbadge ' + (s.checked ? 'blue' : 'gray') + '" style="font-size:10px;">' + (s.checked ? '已分配' : '未分配') + '</span></div>';
  });
  list.innerHTML = html3 || '<div style="text-align:center;padding:30px;color:var(--text-muted);">无匹配员工</div>';
  var countEl = document.getElementById('ras-count');
  if (countEl) countEl.textContent = '已选 ' + checkedCount + ' 人';
}

function toggleRoleAssignItem(el, idx) {
  staffForRoleAssign[idx].checked = !staffForRoleAssign[idx].checked;
  var cb = el.querySelector('input[type="checkbox"]');
  if (cb) cb.checked = staffForRoleAssign[idx].checked;
  if (staffForRoleAssign[idx].checked) {
    el.style.background = 'var(--blue-bg)'; el.style.borderColor = 'var(--blue)';
  } else {
    el.style.background = 'white'; el.style.borderColor = 'var(--border)';
  }
  var countEl = document.getElementById('ras-count');
  if (countEl) countEl.textContent = '已选 ' + staffForRoleAssign.filter(function(s){ return s.checked; }).length + ' 人';
}

function toggleAllRoleAssign(checked) {
  var search = document.getElementById('ras-search') ? document.getElementById('ras-search').value.toLowerCase() : '';
  var roleFilter = document.getElementById('ras-role-filter') ? document.getElementById('ras-role-filter').value : 'all';
  staffForRoleAssign.forEach(function(s, i) {
    var match = true;
    if (search && s.name.toLowerCase().indexOf(search) === -1) match = false;
    if (roleFilter !== 'all' && s.role !== roleFilter) match = false;
    if (match) s.checked = checked;
  });
  renderRoleAssignList();
}

function confirmRoleAssignment() {
  var roleNames = ['管理员', '运维人员', '客房人员', '前台只读'];
  var count = staffForRoleAssign.filter(function(s){ return s.checked; }).length;
  document.getElementById('modal-role-assign').remove();
  showToast('✅ ' + roleNames[_currentAssignRole] + ' 已分配给 ' + count + ' 名员工', 'success');
}

