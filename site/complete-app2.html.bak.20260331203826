function addEscalationEditorRule() {
  var form = document.getElementById('escalation-editor-add-form');
  if (form) form.style.display = 'block';
}
function cancelAddEscalationEditorRule() {
  var form = document.getElementById('escalation-editor-add-form');
  if (form) form.style.display = 'none';
  document.getElementById('ee-type').value = '';
  document.getElementById('ee-urgent').value = '';
  document.getElementById('ee-timeout').value = '30';
  document.getElementById('ee-to').value = '';
  document.getElementById('ee-notify').value = '短信+系统通知';
}
function confirmAddEscalationEditorRule() {
  var type = document.getElementById('ee-type').value;
  var urgent = document.getElementById('ee-urgent').value;
  var timeout = parseInt(document.getElementById('ee-timeout').value) || 30;
  var to = document.getElementById('ee-to').value;
  var notify = document.getElementById('ee-notify').value;
  if (!type || !to) { showToast('请填写工单类型和升级目标', 'error'); return; }
  var typeLabels = {complaint:'🔴 客户投诉',repair:'🔧 设备报修',delivery:'📦 送物服务',invoice:'📄 发票需求',praise:'⭐ 点评表扬',other:'📋 其他'};
  var toLabels = {manager:'前厅经理',supervisor:'客房主管',engineer:'工程师',staff:'前厅员工',admin:'管理员'};
  var condition = urgent ? '工单类型=' + typeLabels[type] + ' && 紧急程度=' + (urgent === 'urgent' ? '紧急' : '十分紧急') : '工单类型=' + typeLabels[type];
  escalationEditorData.push({id:Date.now(),type:type,urgent:urgent?[urgent]:[],condition:condition,to:to,levelLabel:toLabels[to],notify:notify,timeoutMin:timeout,enabled:true});
  cancelAddEscalationEditorRule();
  openEscalationVisualEditor();
  showToast('✅ 规则已添加', 'success');
}
function toggleEscalationRule(idx) {
  escalationEditorData[idx].enabled = !escalationEditorData[idx].enabled;
  openEscalationVisualEditor();
}
function deleteEscalationEditorRule(idx) {
  escalationEditorData.splice(idx, 1);
  openEscalationVisualEditor();
  showToast('规则已删除', 'info');
}
function saveEscalationEditorRules() {
  // 同步到现有的 escalationRules 数组
  escalationRules = escalationEditorData.filter(function(r){return r.enabled;}).map(function(r){
    var typeLabels = {complaint:'🔴 客户投诉',repair:'🔧 设备报修',delivery:'📦 送物服务',invoice:'📄 发票需求',praise:'⭐ 点评表扬',other:'📋 其他'};
    var toLabels = {manager:'manager',supervisor:'supervisor',engineer:'supervisor',staff:'staff',admin:'admin'};
    var timeLabels = {5:'5分钟',15:'15分钟',30:'30分钟',60:'1小时',120:'2小时',240:'4小时'};
    return {type:r.type,typeLabel:typeLabels[r.type],time:r.timeoutMin,timeLabel:timeLabels[r.timeoutMin]||r.timeoutMin+'分钟',to:toLabels[r.to],toLabel:r.levelLabel,notify:r.notify};
  });
  document.getElementById('modal-escalation-editor').remove();
  showToast('✅ 升级规则配置已保存（' + escalationRules.length + ' 条规则生效）', 'success');
}

