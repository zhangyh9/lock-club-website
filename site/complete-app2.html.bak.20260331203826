      // ======= 【改进3】历史记录页面Tab切换逻辑 =======
      function switchHistoryTab(tab, el) {
        document.querySelectorAll('#page-history .tabs .tab').forEach(function(t) { t.classList.remove('active'); });
        el.classList.add('active');
        document.getElementById('hist-content-online').style.display = tab === 'online' ? '' : 'none';
        document.getElementById('hist-content-battery').style.display = tab === 'battery' ? '' : 'none';
        document.getElementById('hist-content-actions').style.display = tab === 'actions' ? '' : 'none';
      }
      function exportHistoryOnline() { showToast('上下线记录已导出', 'success'); }
  // 【改进5】历史记录全量导出：支持时间范围+格式选择
  function exportHistoryRange() {
    var from = document.getElementById('hist-date-from').value;
    var to = document.getElementById('hist-date-to').value;
    var format = document.getElementById('hist-export-format').value;
    var rows = [];
    // 收集三个Tab的记录
    document.querySelectorAll('#hist-content-online .timeline-item').forEach(function(item) {
      rows.push({ type: '上下线', time: item.querySelector('.timeline-time').textContent, content: item.querySelector('.timeline-content h4').textContent + ' - ' + item.querySelector('.timeline-content p').textContent });
    });
    document.querySelectorAll('#hist-content-battery tbody tr').forEach(function(r) {
      var cells = r.querySelectorAll('td');
      if (cells.length >= 4) rows.push({ type: '电量记录', time: cells[0].textContent, content: '电量' + cells[1].textContent + ' - ' + cells[3].textContent });
    });
    document.querySelectorAll('#hist-content-actions tbody tr').forEach(function(r) {
      var cells = r.querySelectorAll('td');
      if (cells.length >= 4) rows.push({ type: '操作记录', time: cells[0].textContent, content: cells[1].textContent + ' - ' + cells[2].textContent });
    });
    if (format === 'csv') {
      var csv = '\uFEFF类型,时间,详情\n';
      rows.forEach(function(r){ csv += r.type + ',' + r.time + ',' + r.content + '\n'; });
      var blob = new Blob([csv], {type:'text/csv;charset=utf-8'});
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
      a.download = '设备历史记录_' + from + '_to_' + to + '.csv';
      a.click();
    } else {
      var json = JSON.stringify(rows, null, 2);
      var blob = new Blob([json], {type:'application/json'});
      var a = document.createElement('a'); a.href = URL.createObjectURL(blob);
      a.download = '设备历史记录_' + from + '_to_' + to + '.json';
      a.click();
    }
    URL.revokeObjectURL(a.href);
    showToast('已导出 ' + rows.length + ' 条历史记录（' + format.toUpperCase() + '）', 'success');
  }
      function exportHistoryBattery() { showToast('电量记录已导出', 'success'); }
      function exportHistoryActions() { showToast('操作记录已导出', 'success'); }
