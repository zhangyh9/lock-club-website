function submitBuildingCRUD(id) {
  var name = document.getElementById('bld-crud-name').value.trim();
  var floors = parseInt(document.getElementById('bld-crud-floors').value) || 0;
  var rooms = parseInt(document.getElementById('bld-crud-rooms').value) || 0;
  if (!name || !floors) { showToast('请填写楼栋名称和楼层数', 'error'); return; }
  if (id) {
    var b = buildingData.find(function(b){ return b.id === id; });
    if (b) { b.name=name; b.floors=floors; b.rooms=rooms; b.address=document.getElementById('bld-crud-addr').value.trim(); b.manager=document.getElementById('bld-crud-mgr').value.trim(); b.phone=document.getElementById('bld-crud-phone').value.trim(); b.remark=document.getElementById('bld-crud-remark').value.trim(); b.status=document.getElementById('bld-crud-status').value; }
    showToast('✅ 楼栋 "' + name + '" 信息已更新', 'success');
  } else {
    buildingData.push({id:'B' + Date.now(), name:name, floors:floors, rooms:rooms, address:document.getElementById('bld-crud-addr').value.trim(), status:'active', manager:document.getElementById('bld-crud-mgr').value.trim(), phone:document.getElementById('bld-crud-phone').value.trim(), remark:document.getElementById('bld-crud-remark').value.trim()});
    showToast('🏢 新楼栋 "' + name + '" 已创建（共' + floors + '层）', 'success');
  }
  document.getElementById('modal-building-crud') && document.getElementById('modal-building-crud').remove();
  if (typeof renderBuildingList === 'function') renderBuildingList();
  // Refresh building stats cards
  var totalEl = document.getElementById('bldm-stat-total');
  if (totalEl) totalEl.textContent = buildingData.length;
  var floorsEl = document.getElementById('bldm-stat-floors');
  if (floorsEl) floorsEl.textContent = buildingData.reduce(function(s, b){ return s + (parseInt(b.floors) || 0); }, 0);
  var roomsEl = document.getElementById('bldm-stat-rooms');
  if (roomsEl) roomsEl.textContent = buildingData.reduce(function(s, b){ return s + (parseInt(b.rooms) || 0); }, 0);
}

