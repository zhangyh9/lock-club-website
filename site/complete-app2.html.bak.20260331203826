  var tempData = [22, 24, 23, 25, 24, 23, 24];
  var maxKwh = Math.max.apply(null, kwhData);

  var barsHtml = kwhData.map(function(kwh, i) {
    var h = Math.round((kwh / (maxKwh * 1.2)) * 120);
    var color = kwh > 7 ? 'var(--red)' : kwh > 5 ? 'var(--orange)' : 'var(--green)';
    return '<div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;">' +
