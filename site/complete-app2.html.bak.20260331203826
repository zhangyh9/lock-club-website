// 【改进5】startKanbanDrag/allowKanbanDrop/dropKanbanCard - 工单看板拖拽函数
// 业务逻辑：工单看板（modal-wo-kanban）中的3列拖拽交互，支持工单卡片在待接受/处理中/已完成列之间流转
var _kanbanDraggedWo = null;
function startKanbanDrag(event, woId) {
  _kanbanDraggedWo = woId;
  event.dataTransfer.effectAllowed = 'move';
  event.dataTransfer.setData('text/plain', woId);
  event.target.style.opacity = '0.5';
}
function allowKanbanDrop(event) {
  event.preventDefault();
  event.dataTransfer.dropEffect = 'move';
}
function dropKanbanCard(event, newStatus) {
  event.preventDefault();
  event.stopPropagation();
  if (!_kanbanDraggedWo) return;
  var woId = _kanbanDraggedWo;
  _kanbanDraggedWo = null;
  var card = document.querySelector('[data-wo="' + woId + '"]');
  if (card) card.style.opacity = '1';
  var statusLabels = {pending:'⏳ 待接受', processing:'🔄 处理中', done:'✅ 已完成'};
  showToast('📋 工单 ' + woId + ' 已移至「' + statusLabels[newStatus] + '」', 'success');
  // Move card DOM element to new column
  var targetCol = document.getElementById('kanban-' + newStatus);
  if (targetCol && card) {
    targetCol.appendChild(card);
    // Update card's data-status attribute
    card.setAttribute('data-status', newStatus);
  }
  // Update counter
  updateKanbanCounters();
}

function updateKanbanCounters() {
  var cols = ['pending', 'processing', 'done'];
  cols.forEach(function(col) {
    var el = document.getElementById('kanban-' + col + '-count');
    var container = document.getElementById('kanban-' + col);
    if (el && container) {
      var cards = container.querySelectorAll('.kanban-card');
      el.textContent = cards.length;
    }
  });
}

