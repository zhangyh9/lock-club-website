    return true;
  });
  filtered.sort(function(a, b){ return b.score - a.score; });
  filtered.forEach(function(d, i){ d.rank = i + 1; });
  var rows = '';
  filtered.forEach(function(d) {
    var grade = d.score >= 95 ? {label:'A', color:'var(--green)', bg:'var(--green-bg)'} : d.score >= 85 ? {label:'B', color:'var(--blue)', bg:'var(--blue-bg)'} : d.score >= 75 ? {label:'C', color:'var(--orange)', bg:'var(--orange-bg)'} : {label:'D', color:'var(--red)', bg:'var(--red-bg)'};
