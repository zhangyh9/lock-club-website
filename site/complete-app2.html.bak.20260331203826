    var slaTime = new Date(slaDateStr.replace('今天','2026-03-29'));
    var diffMs = slaTime - now;
    var diffMin = Math.round(diffMs / 60000);
    if (diffMin < 0) overdueCount++;
    else if (diffMin <= 30) urgentCount++;
