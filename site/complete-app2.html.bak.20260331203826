  if (idx >= 0) {
    fwSelectedDevices.splice(idx, 1);
    el.classList.remove('selected');
    el.style.borderColor = 'var(--border)';
    el.style.background = 'white';
  } else {
    fwSelectedDevices.push(room);
    el.classList.add('selected');
    el.style.borderColor = 'var(--blue)';
    el.style.background = 'var(--blue-bg)';
  }
  document.getElementById('fw-upgrade-btn').textContent = '📦 开始升级（'+fwSelectedDevices.length+'台）';
}

function selectAllFWDevices() {
  fwSelectedDevices = ['301','305','201','202','203'];
  document.querySelectorAll('.fw-device-chip').forEach(function(c){
    c.classList.add('selected');
    c.style.borderColor = 'var(--blue)';
    c.style.background = 'var(--blue-bg)';
  });
  document.getElementById('fw-upgrade-btn').textContent = '📦 开始升级（5台）';
}

function clearFWSelection() {
  fwSelectedDevices = [];
  document.querySelectorAll('.fw-device-chip').forEach(function(c){
    c.classList.remove('selected');
    c.style.borderColor = 'var(--border)';
    c.style.background = 'white';
  });
  document.getElementById('fw-upgrade-btn').textContent = '📦 开始升级（0台）';
}

function checkFWUpdate() {
  showToast('🔄 正在检查固件更新...', 'info');
  setTimeout(function(){
    showToast('📢 已是最新版本 v2.4.0，暂无可用更新', 'success');
  }, 1500);
}

function startFWUpgrade() {
  if (fwSelectedDevices.length === 0) { showToast('请先选择要升级的设备', 'error'); return; }
