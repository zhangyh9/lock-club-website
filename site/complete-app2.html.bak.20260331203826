        setTimeout(injectAlertDetailButton, 200);
      }
      if (pageName === 'config') {
        setTimeout(function() { switchConfigTab('basic', document.getElementById('cfg-tab-basic')); }, 100);
      }
    };
    showPage._hooked = true;
  }
  // 页面元素初始化
  setTimeout(function() {
    renderInvoiceFilteredList();
    if (typeof renderBlacklist === 'function') renderBlacklist();
    injectAlertDetailButton();
    switchConfigTab('basic', document.getElementById('cfg-tab-basic'));
    // 【P13修复】发票搜索和操作日志筛选事件绑定（统一管理）
    var invSearch = document.getElementById('inv-search-input');
    if (invSearch) { window._invSearchHandler = applyInvoiceSearch; invSearch.addEventListener('input', applyInvoiceSearch); }
    // 【P13修复】_oplogHandlers存储{handler, type}，type区分change/input以正确清理
    var _oplogHandlers = {};
    // P13.1修复：oplog-module-filter实际DOM id为oplog-type-filter（同名不同功能），删除无效oplog-module-filter绑定
    ['oplog-user-filter','oplog-type-filter'].forEach(function(id) {
      var el = document.getElementById(id);
      if (el) { _oplogHandlers[id] = {handler: applyOplogFilter, type: 'change'}; el.addEventListener('change', applyOplogFilter); }
    });
    // P13.2修复：oplog-date-start实际DOM id为oplog-date-from，oplog-date-end实际DOM id为oplog-date-to
    var oplogDateStart = document.getElementById('oplog-date-from');
    if (oplogDateStart) { _oplogHandlers.dateStart = {handler: applyOplogFilter, type: 'change'}; oplogDateStart.addEventListener('change', applyOplogFilter); }
    var oplogDateEnd = document.getElementById('oplog-date-to');
    if (oplogDateEnd) { _oplogHandlers.dateEnd = {handler: applyOplogFilter, type: 'change'}; oplogDateEnd.addEventListener('change', applyOplogFilter); }
    var oplogTarget = document.getElementById('oplog-target');
    if (oplogTarget) { _oplogHandlers.target = {handler: applyOplogFilter, type: 'input'}; oplogTarget.addEventListener('input', applyOplogFilter); }
  }, 400);
  // 【P13修复】统一showPageHook：合并4个独立showPage重写，避免重复覆盖
  window._showPageHook = function(pageName) {
    // 通知中心
    if (pageName !== 'notif') cleanupNotifCenterEvents();
    else bindNotifCenterEvents();
    // 办理记录
    if (pageName !== 'records') cleanupRecordEvents();
    else bindRecordEvents();
    // 发票（搜索清理）
    if (pageName !== 'invoice' && invSearch && window._invSearchHandler) invSearch.removeEventListener('input', window._invSearchHandler);
    // 操作日志（_oplogHandlers存储{handler, type}，type区分change/input）
    if (pageName !== 'config') {
      Object.keys(_oplogHandlers).forEach(function(id) {
        var el = document.getElementById(id);
        var info = _oplogHandlers[id];
        if (el && info && info.handler) el.removeEventListener(info.type || 'change', info.handler);
      });
    }
  };
});
