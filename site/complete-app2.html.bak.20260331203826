function filterAlertTable(tab, el) {
  _alertCurrentTab = tab;
  var tabContainer = document.querySelector('#page-alert .card-tabs');
  if (tabContainer) {
    tabContainer.querySelectorAll('.card-tab').forEach(function(t) {
      t.classList.remove('active');
      t.style.background = '';
      t.style.color = '';
    });
    if (el) {
      el.classList.add('active');
      el.style.background = 'var(--blue)';
      el.style.color = 'white';
    }
  }
  var tbody = document.getElementById('alert-table-body');
  if (!tbody) return;
  var rows = tbody.querySelectorAll('tr');
  var matchCount = 0;
  rows.forEach(function(row) {
    var status = row.getAttribute('data-status') || '';
    var show = tab === 'all'
      || (tab === 'pending' && (status === 'pending' || status === ''))
      || (tab === 'done' && (status === 'resolved' || status === 'done' || status === 'recovered' || status === 'ignored'));
    // T19: apply type filter
    if (show && _alertTypeFilter) {
      var badge = row.querySelector('.tbadge');
      var text = badge ? badge.textContent : '';
      if (_alertTypeFilter === 'offline' && text.indexOf('离线') < 0) show = false;
      else if (_alertTypeFilter === 'lowbat' && text.indexOf('低电量') < 0 && text.indexOf('电量') < 0) show = false;
      else if (_alertTypeFilter === 'door' && text.indexOf('门锁') < 0 && text.indexOf('异常') < 0) show = false;
      else if (_alertTypeFilter === 'temp' && text.indexOf('温度') < 0 && text.indexOf('高温') < 0 && text.indexOf('低温') < 0) show = false;
    }
    row.style.display = show ? '' : 'none';
    if (show) matchCount++;
  });
  var countEl = document.getElementById('alert-count-label');
  if (countEl) countEl.textContent = '共 ' + matchCount + ' 条';
}

