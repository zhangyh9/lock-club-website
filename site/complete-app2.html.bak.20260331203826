function renderBlacklist() {
  var tbody = document.getElementById('bl-table-body');
  if (!tbody) return;
  var kw = document.getElementById('bl-search') ? document.getElementById('bl-search').value.toLowerCase().trim() : '';
  var typeFilter = document.getElementById('bl-type-filter') ? document.getElementById('bl-type-filter').value : 'all';
  var reasonFilter = document.getElementById('bl-reason-filter') ? document.getElementById('bl-reason-filter').value : 'all';
  var filtered = blacklistStore.filter(function(b) {
    var matchKw = !kw || b.name.toLowerCase().indexOf(kw) >= 0 || b.phone.indexOf(kw) >= 0 || b.idCard.indexOf(kw) >= 0;
    var matchType = typeFilter === 'all' || (typeFilter === 'released' ? b.status === 'released' : b.type === typeFilter && b.status === 'active');
    var matchReason = reasonFilter === 'all' || b.reason === reasonFilter;
    return matchKw && matchType && matchReason;
  });
  var rows = filtered.map(function(b) {
    var typeLabel = b.type === 'permanent' ? '<span class="tbadge red">🔒 永久封禁</span>' : '<span class="tbadge orange">⏳ 临时封禁</span>';
