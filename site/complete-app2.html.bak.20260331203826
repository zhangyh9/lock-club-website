function changeReportPeriod() {
  var period = document.getElementById('rpt-period') ? document.getElementById('rpt-period').value : 'thismonth';
  var startInput = document.getElementById('rpt-date-start');
  var endInput = document.getElementById('rpt-date-end');
  var today = new Date();
  var y = today.getFullYear(), m = today.getMonth();
  var fmt = function(d) { return d.toISOString().slice(0,10); };
  if (period === 'today') {
    if (startInput) startInput.value = fmt(today);
    if (endInput) endInput.value = fmt(today);
  } else if (period === 'yesterday') {
    var yd = new Date(today); yd.setDate(today.getDate()-1);
    if (startInput) startInput.value = fmt(yd);
    if (endInput) endInput.value = fmt(yd);
  } else if (period === 'thisweek') {
    var wd = new Date(today); wd.setDate(today.getDate()-today.getDay());
    if (startInput) startInput.value = fmt(wd);
    if (endInput) endInput.value = fmt(today);
  } else if (period === 'thismonth') {
    var md = new Date(y, m, 1);
    if (startInput) startInput.value = fmt(md);
    if (endInput) endInput.value = fmt(today);
  } else if (period === 'lastmonth') {
    var lm = new Date(y, m-1, 1), lme = new Date(y, m, 0);
    if (startInput) startInput.value = fmt(lm);
    if (endInput) endInput.value = fmt(lme);
  }
  showToast('📅 已切换至' + (document.getElementById('rpt-period')||{}).options[(document.getElementById('rpt-period')||{}).selectedIndex||0].textContent, 'info');
}

function generateReport() {
  var period = document.getElementById('rpt-period') ? document.getElementById('rpt-period').value : 'thismonth';
  var building = document.getElementById('rpt-building') ? document.getElementById('rpt-building').value : 'all';
