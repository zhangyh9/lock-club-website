function openCheckoutSettleModal(room, name, nights, pricePerNight) {
  _cosData = {room:room, name:name, nights:nights||2, pricePerNight:pricePerNight||128};
  var roomFee = (nights||2) * (pricePerNight||128);
  var deposit = 100;
  var finalAmount = Math.max(0, roomFee - deposit);
  var roomNumEl = document.getElementById('cos-room-num');
  if (roomNumEl) roomNumEl.textContent = room;
  var guestNameEl = document.getElementById('cos-guest-name');
  if (guestNameEl) guestNameEl.textContent = name;
  var roomEl = document.getElementById('cos-room');
  if (roomEl) roomEl.textContent = room;
  var nightsEl = document.getElementById('cos-nights');
  if (nightsEl) nightsEl.textContent = (nights||2) + '晚';
  var nightCountEl = document.getElementById('cos-night-count');
  if (nightCountEl) nightCountEl.textContent = nights||2;
  var nightPriceEl = document.getElementById('cos-night-price');
  if (nightPriceEl) nightPriceEl.textContent = pricePerNight||128;
  var roomFeeEl = document.getElementById('cos-room-fee');
  if (roomFeeEl) roomFeeEl.textContent = '¥' + roomFee;
  var totalEl = document.getElementById('cos-total');
  if (totalEl) totalEl.textContent = '¥' + roomFee;
  var depositUsedEl = document.getElementById('cos-deposit-used');
  if (depositUsedEl) depositUsedEl.textContent = '¥' + Math.min(deposit, roomFee);
  var refundEl = document.getElementById('cos-refund');
  if (refundEl) refundEl.textContent = '¥' + Math.max(0, deposit - roomFee);
  var finalAmtEl = document.getElementById('cos-final-amount');
  if (finalAmtEl) {
    finalAmtEl.textContent = '¥' + finalAmount;
    finalAmtEl.style.color = finalAmount > 0 ? 'var(--blue)' : 'var(--green)';
  }
  _cosPaymentMethod = 'wechat';
  document.querySelectorAll('[id^="pm-"]').forEach(function(el){ el.style.borderColor = 'var(--border)'; el.style.background = 'white'; });
  var wechatEl = document.getElementById('pm-wechat');
  if (wechatEl) { wechatEl.style.borderColor = 'var(--blue)'; wechatEl.style.background = 'var(--blue-bg)'; }
  openModal('checkout-settle');
}
function selectPaymentMethod(el, method) {
  _cosPaymentMethod = method;
  document.querySelectorAll('[id^="pm-"]').forEach(function(e){ e.style.borderColor = 'var(--border)'; e.style.background = 'white'; });
  el.style.borderColor = 'var(--blue)';
  el.style.background = 'var(--blue-bg)';
}
function submitCheckoutSettlement() {
  if (!_cosData) return;
  var finalAmtEl = document.getElementById('cos-final-amount');
  var finalAmt = finalAmtEl ? (parseInt(finalAmtEl.textContent.replace('¥','')) || 0) : 0;
  var paymentText = {wechat:'微信支付',alipay:'支付宝',cash:'现金',card:'银行卡'}[_cosPaymentMethod] || _cosPaymentMethod;
  var invoiceOption = document.querySelector('input[name="invoice-option"]:checked');
  var invoiceText = invoiceOption ? {electronic:'电子发票',paper:'纸质发票',none:'不开票'}[invoiceOption.value] : '';
  closeModal('checkout-settle');
  showToast('✅ 退房结算完成！房间 ' + _cosData.room + ' 已转为空房，实付 ' + (finalAmt > 0 ? '¥' + finalAmt : '¥0（押金抵扣）') + '，支付方式：' + paymentText + '，发票：' + invoiceText, 'success');
  var roomCards = document.querySelectorAll('.room-card[data-room="' + _cosData.room + '"]');
  roomCards.forEach(function(card) {
    var badge = card.querySelector('.room-badge');
    if (badge) { badge.className = 'room-badge badge-empty'; badge.textContent = '空房'; }
    card.classList.remove('alert','low');
    card.classList.add('empty');
    var statusAttr = card.getAttribute('data-status');
    if (statusAttr) card.setAttribute('data-status', 'empty');
  });
  _cosData = null;
}
