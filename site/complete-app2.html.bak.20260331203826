    function renderEnergyChart() {
      var canvas = document.getElementById('energy-chart-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      var data = energyData[currentEnergyTab];
      var w = canvas.width;
      var h = canvas.height;
      var padLeft = 45, padRight = 15, padTop = 15, padBottom = 35;
      var chartW = w - padLeft - padRight;
      var chartH = h - padTop - padBottom;
      ctx.clearRect(0, 0, w, h);
      // Draw grid lines
      ctx.strokeStyle = '#e8e8e8';
      ctx.lineWidth = 0.5;
      for (var i = 0; i <= 4; i++) {
        var y = padTop + (chartH / 4) * i;
        ctx.beginPath(); ctx.moveTo(padLeft, y); ctx.lineTo(padLeft + chartW, y); ctx.stroke();
        // Y label for power
        ctx.fillStyle = '#999';
        ctx.font = '10px sans-serif';
        ctx.textAlign = 'right';
        var maxPower = Math.max.apply(null, data.power);
        var yVal = Math.round(maxPower * (1 - i / 4));
        ctx.fillText(yVal, padLeft - 4, y + 3);
      }
      // X labels
      ctx.textAlign = 'center';
      var step = Math.ceil(data.labels.length / 8);
      for (var i = 0; i < data.labels.length; i += step) {
        var x = padLeft + (i / (data.labels.length - 1)) * chartW;
        ctx.fillText(data.labels[i], x, h - 6);
      }
      // Draw power line (blue)
      var maxP = Math.max.apply(null, data.power);
      var maxW = Math.max.apply(null, data.water);
      function drawLine(values, color, maxVal) {
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = 2;
        ctx.fillStyle = color + '22';
        values.forEach(function(v, i) {
          var x = padLeft + (i / (values.length - 1)) * chartW;
          var y = padTop + chartH - (v / maxVal) * chartH;
          if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);
        });
        ctx.stroke();
        // Area fill
        var lastX = padLeft + chartW;
        var baseY = padTop + chartH;
        ctx.lineTo(lastX, baseY);
        ctx.lineTo(padLeft, baseY);
        ctx.closePath();
        ctx.fill();
        // Dots
        values.forEach(function(v, i) {
          var x = padLeft + (i / (values.length - 1)) * chartW;
          var y = padTop + chartH - (v / maxVal) * chartH;
          ctx.beginPath();
          ctx.arc(x, y, 3, 0, Math.PI * 2);
          ctx.fillStyle = color;
          ctx.fill();
          ctx.strokeStyle = 'white';
          ctx.lineWidth = 1.5;
          ctx.stroke();
        });
      }
      drawLine(data.power.map(function(v) { return v; }), '#1890ff', maxP);
      drawLine(data.water.map(function(v) { return v / (maxW / maxP); }), '#fa8c16', maxP);
      // Update summary
      var totalPower = data.power.reduce(function(a, b) { return a + b; }, 0);
      var totalWater = data.water.reduce(function(a, b) { return a + b; }, 0);
      var elPowerTotal = document.getElementById('echart-power-total');
      var elWaterTotal = document.getElementById('echart-water-total');
      var elPowerAvg = document.getElementById('echart-power-avg');
      var elCostTotal = document.getElementById('echart-cost-total');
      if (elPowerTotal) elPowerTotal.textContent = totalPower.toFixed(1);
      if (elWaterTotal) elWaterTotal.textContent = Math.round(totalWater);
      if (elPowerAvg) elPowerAvg.textContent = (totalPower / 8).toFixed(1);
      if (elCostTotal) elCostTotal.textContent = '¥' + (totalPower * 0.52).toFixed(1);
    }
    // Auto-render energy chart when energy page is shown
    var _lastEnergyPage = '';
    function checkEnergyPage() {
      var energyPage = document.getElementById('page-energy');
