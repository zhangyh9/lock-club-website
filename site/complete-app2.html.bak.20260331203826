function searchOplogByKeyword(keyword) {
  if (!keyword || !keyword.trim()) {
    showToast('请输入搜索关键词', 'info');
    return;
  }
  var kw = keyword.trim().toLowerCase();
  var tbody = document.getElementById('oplog-table-body');
  if (!tbody) return;
  var rows = tbody.querySelectorAll('tr');
  var matchCount = 0;
  rows.forEach(function(row) {
    var text = row.textContent.toLowerCase();
    if (text.indexOf(kw) >= 0) {
      row.style.display = '';
      matchCount++;
    } else {
      row.style.display = 'none';
    }
  });
  document.getElementById('oplog-count-label') && (document.getElementById('oplog-count-label').textContent = '匹配 ' + matchCount + ' 条记录');
  showToast('🔍 找到 ' + matchCount + ' 条匹配记录', 'info');
}
function clearOplogSearch() {
  var input = document.getElementById('oplog-keyword-search');
