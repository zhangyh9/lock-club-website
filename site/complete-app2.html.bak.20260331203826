// 渲染配置页面楼栋列表
function renderCfgBuildingList() {
  var tbody = document.getElementById('cfg-bldg-list-body');
  if (!tbody) return;
  tbody.innerHTML = buildingData.map(function(b) {
    var online = Math.floor((b.rooms || 0) * 0.85);
    var offline = (b.rooms || 0) - online;
    var occ = Math.floor(Math.random() * 40 + 50);
    return '<tr>' +
      '<td><span style="font-weight:600;">' + b.name + '</span></td>' +
      '<td>' + b.floors + '层</td><td>' + b.rooms + '间</td>' +
      '<td style="color:var(--green);">' + online + '台</td><td style="color:var(--red);">' + offline + '台</td>' +
      '<td><span style="color:var(--blue);">' + occ + '%</span></td>' +
      '<td><span class="tbadge ' + (b.status==='active'?'green':'gray') + '">' + (b.status==='active'?'启用':'停用') + '</span></td>' +
      '<td><button class="action-btn small" onclick="openEditBldgConfig(\'' + b.id + '\')">编辑</button> <button class="action-btn small red" onclick="confirmDeleteBldgFromConfig(\'' + b.id + '\',\'' + b.name + '\',' + b.rooms + ')">删除</button></td>' +
    '</tr>';
  }).join('');
  // Update stat summary
  var statEl = document.getElementById('bldg-stat-summary');
  if (statEl) {
    var totalFloors = buildingData.reduce(function(s, b){ return s + (parseInt(b.floors)||0); }, 0);
    var totalRooms = buildingData.reduce(function(s, b){ return s + (parseInt(b.rooms)||0); }, 0);
    statEl.textContent = '共 ' + buildingData.length + ' 栋 · ' + totalFloors + ' 层 · ' + totalRooms + ' 间';
  }
}

