// 【函数3】switchDevTab - 设备详情页Tab切换
function switchDevTab(tab) {
  var tabs = ['info', 'remote', 'unlock-log', 'runtime', 'binding', 'keys'];
  tabs.forEach(function(t) {
    var btn = document.getElementById('dev-tab-' + t);
    var content = document.getElementById('dev-content-' + t);
    if (btn) {
      if (t === tab) {
        btn.classList.add('active');
        btn.style.background = 'var(--blue)';
        btn.style.color = 'white';
      } else {
        btn.classList.remove('active');
        btn.style.background = '';
        btn.style.color = '';
      }
    }
    if (content) {
      content.style.display = t === tab ? '' : 'none';
    }
  });
}

