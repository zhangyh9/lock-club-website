function resolveAlertEntry(idx) {
  var d = alertData[idx];
  if (!d) return;
  if (d.status === '已处理') { showToast('该告警已处理，无需重复操作', 'warning'); return; }
  d.status = '已处理';
  d.resolvedTime = new Date().toLocaleString('zh-CN');
  // Re-render alert table
  var tbody = document.getElementById('alert-table-body');
  if (tbody) {
    var rows = tbody.querySelectorAll('tr');
    rows.forEach(function(row) {
      var cells = row.querySelectorAll('td');
      if (cells.length >= 6 && cells[2] && cells[2].textContent.indexOf(d.time) >= 0) {
        cells[3].innerHTML = '<span class="tbadge green">✅ 已处理</span>';
        var lastCell = cells[cells.length - 1];
        if (lastCell) {
          var btns = lastCell.querySelectorAll('button');
          btns.forEach(function(b) { if (b.textContent.indexOf('处理') >= 0) b.remove(); });
        }
      }
    });
  }
  showToast('✅ 告警已标记处理：' + d.type, 'success');
}

function resolveAlert(idx) { resolveAlertEntry(idx); }

