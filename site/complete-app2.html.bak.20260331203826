function submitFaultWorkorder(uuid, roomNum) {
  var title = document.getElementById('fault-wo-title').value.trim();
  var desc = document.getElementById('fault-wo-desc') ? document.getElementById('fault-wo-desc').value.trim() : '';
  var priority = document.getElementById('fault-priority-select') ? document.getElementById('fault-priority-select').value : 'normal';
  var faultType = document.getElementById('fault-type-select') ? document.getElementById('fault-type-select').value : 'other';
  if (!title) { showToast('请填写工单标题', 'error'); return; }
  var woId = 'WO-' + new Date().toISOString().slice(0,10).replace(/-/g,'') + '-' + Math.random().toString(36).slice(2,6).toUpperCase();
  var now = new Date();
  // Add to SLA store
  if (typeof workorderSLAStore !== 'undefined') {
    workorderSLAStore.unshift({id:woId, title:title, type:faultType, status:'pending', priority:priority, room:roomNum, handler:'系统', createTime:now.toISOString().slice(0,16).replace('T',' '), desc:desc, slaMinutes:60});
  }
  // Add to main workorder list
  if (typeof _woList !== 'undefined') {
    _woList.unshift({id:woId, type:faultType, room:roomNum, customer:'系统', phone:'--', desc:title, priority:priority, status:'pending', assign:'待分配', create:now.toLocaleString('zh-CN',{month:'numeric',day:'numeric',hour:'2-digit',minute:'2-digit'}).replace(/\//g,'-'), sla:'--', satisfaction:0});
