    var isOffline = r.lock.indexOf('⚠️') >= 0;
    var isLowBattery = r.battery < IOT_CONST.BATTERY_CRITICAL;
    var badgeClass, badgeText, statusColor;
    if (isOffline) {
      badgeClass = 'badge-alert'; badgeText = '离线'; statusColor = 'var(--red)';
    } else if (isLowBattery) {
      badgeClass = 'badge-low'; badgeText = '低电量'; statusColor = 'var(--orange)';
    } else if (r.status === 'in') {
      badgeClass = 'badge-in'; badgeText = '入住'; statusColor = 'var(--green)';
    } else {
      badgeClass = 'badge-empty'; badgeText = '空房'; statusColor = 'var(--blue)';
    }
    var lockClass = isOffline ? 'red' : 'green';
    var battClass = r.battery < IOT_CONST.BATTERY_CRITICAL ? 'red' : r.battery < IOT_CONST.BATTERY_LOW ? 'orange' : 'green';
    var elecClass = r.electricity > 30 ? 'red' : r.electricity > 20 ? 'orange' : 'green';
    // 【P62修复】设备离线或严重低电量时应用disabled样式（卡片灰显+房间号删除线）
    var cardClass = '';
    if (isOffline || isLowBattery) {
      cardClass = 'disabled';
