      }, {once: true});
    }
  }
  // 立即隐藏弹窗（防止初始化时覆盖整个屏幕拦截侧边栏点击）
  var modal = document.getElementById('modal-dev-restart-confirm');
  if (modal) modal.classList.add('hidden');
}

