  syncWorkorderTableFromData();
}

// ============================================================
// 【物联后台 v3.6 改进2】工单创建后自动同步更新表格
// 理由：submitCreateWorkorder 只把数据加入 workorderData，但表格 DOM 是静态 hardcoded 的，
// 新工单创建后表格不会更新，用户看不到新工单。
// 改进：在 workorderData 变化后重新渲染表格，同时计算 SLA 截止时间。
// ============================================================
var _slaConfig = {
  low: 48 * 3600 * 1000,
  normal: 24 * 3600 * 1000,
  high: 4 * 3600 * 1000,
  urgent: 1 * 3600 * 1000
};

function getSlaDeadlineMs(priority, createTimeMs) {
  var map = {low: 48*3600000, normal: 24*3600000, high: 4*3600000, urgent: 1*3600000};
  return createTimeMs + (map[priority] || map.normal);
}

function formatSlaRemaining(deadlineMs) {
  var now = Date.now();
  var diff = deadlineMs - now;
  if (diff <= 0) return {text: '已超时', color: 'var(--red)', urgent: true};
  var hours = Math.floor(diff / 3600000);
  var mins = Math.floor((diff % 3600000) / 60000);
  var secs = Math.floor((diff % 60000) / 1000);
  if (hours > 0) return {text: '⏰ ' + hours + 'h ' + mins + 'm', color: hours < 2 ? 'var(--orange)' : 'var(--green)', urgent: hours < 2};
  return {text: '⏰ ' + mins + 'm ' + secs + 's', color: 'var(--orange)', urgent: true};
}

function buildWorkorderRowHtml(wo, idx) {
  var createMs = wo._createMs || Date.now();
  var deadlineMs = wo._deadline || getSlaDeadlineMs(wo.priority || 'normal', createMs);
  var sla = formatSlaRemaining(deadlineMs);
  var isOverdue = wo.status !== 'done' && new Date() > new Date(deadlineMs);
  var priorityColor = {urgent:'var(--red)', high:'var(--orange)', normal:'var(--blue)', low:'var(--gray)'}[wo.priority] || 'var(--blue)';
  var statusBadge = wo.status === 'done' ? '<span class="tbadge green">已完成</span>'
    : wo.status === 'processing' ? '<span class="tbadge purple">处理中</span>'
    : '<span class="tbadge orange">待接受</span>';
  var typeIcons = {complaint:'🔴', review:'⭐', invoice:'📄', delivery:'📦', clean:'🧹', maintain:'🔧', other:'📝'};
  var typeIcon = typeIcons[wo.type] || '📋';
  var priorityLabels = {urgent:'🔴紧急', high:'🟠高', normal:'🟡普通', low:'⚪低'};
  var priLabel = priorityLabels[wo.priority] || '🟡普通';
  var rowBg = isOverdue && wo.status !== 'done' ? 'background:var(--red-bg);' : '';
  var slaDisplay = wo.status === 'done' ? '<span class="tbadge green">已完成</span>'
    : isOverdue ? '<span style="color:var(--red);font-size:11px;font-weight:700;">⚠️ 已超时</span>'
    : '<span style="color:' + sla.color + ';font-size:11px;font-weight:600;">' + sla.text + '</span>';
  return '<tr data-status="' + wo.status + '" data-priority="' + wo.priority + '" style="' + rowBg + 'cursor:pointer;" onclick="openWorkorderDetailAndUpdate(\'' + wo.id + '\')">' +
    '<td><input type="checkbox" class="wo-row-check" data-wo-id="' + wo.id + '" onchange="toggleWorkorderRow(this, \'' + wo.id + '\')" style="accent-color:var(--blue);cursor:pointer;" onclick="event.stopPropagation()"></td>' +
    '<td style="font-size:11px;font-family:monospace;font-weight:700;color:var(--blue);">' + wo.id + '</td>' +
    '<td><span class="tbadge" style="color:' + priorityColor + ';background:var(--' + (wo.priority === 'urgent' || wo.priority === 'high' ? 'orange' : 'blue') + '-bg);">' + typeIcon + ' ' + (wo.typeLabel || wo.type) + '</span></td>' +
    '<td><b>' + wo.room + '</b></td>' +
    '<td style="font-size:12px;"><b>' + (wo.customer || '匿名') + '</b><br><span style="font-size:10px;color:var(--text-muted);">' + (wo.phone || '') + '</span></td>' +
    '<td style="font-size:11px;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="' + wo.content + '">' + wo.content + '</td>' +
    '<td><span class="tbadge" style="color:' + priorityColor + ';background:' + priorityColor.replace('var(--', 'var(--').replace(')', '-bg)').replace('var(--red)', 'var(--red-bg)').replace('var(--orange)', 'var(--orange-bg)').replace('var(--blue)', 'var(--blue-bg)').replace('var(--gray)', 'var(--bg)') + ';">' + priLabel + '</span></td>' +
    '<td style="font-size:11px;">' + slaDisplay + '</td>' +
    '<td>' + statusBadge + '</td>' +
    '<td style="font-size:11px;">' + (wo.assignee ? '<span class="tbadge blue" style="font-size:10px;padding:2px 6px;">👤 ' + wo.assignee + '</span>' : '<span style="color:var(--text-muted);">未分配</span>') + '</td>' +
    '<td style="font-size:11px;color:var(--text-muted);">' + wo.time + '</td>' +
    '<td style="font-size:11px;color:var(--text-muted);">' + (wo.completeTime || '--') + '</td>' +
    '<td onclick="event.stopPropagation()">' +
    (wo.status !== 'done' ? '<button class="action-btn small" onclick="openWorkorderDetailAndUpdate(\'' + wo.id + '\')" style="padding:3px 8px;font-size:11px;background:var(--blue);color:white;border:none;border-radius:4px;">处理</button>' : '<button class="action-btn small" onclick="openWorkorderDetailAndUpdate(\'' + wo.id + '\')" style="padding:3px 8px;font-size:11px;">查看</button>') +
    '</td></tr>';
}

function syncWorkorderTableFromData() {
  var tbody = document.getElementById('workorder-table-body');
  if (!tbody || !Array.isArray(workorderData)) return;
  // Re-attach _createMs and _deadline to each workorder if not present
  workorderData.forEach(function(wo) {
    if (!wo._createMs) {
      var createDate = new Date();
      var timeParts = wo.time.match(/(\d+):(\d+)/);
      if (timeParts) {
        createDate.setHours(parseInt(timeParts[1]), parseInt(timeParts[2]), 0, 0);
      }
      wo._createMs = createDate.getTime();
    }
    if (!wo._deadline) {
      wo._deadline = getSlaDeadlineMs(wo.priority || 'normal', wo._createMs);
    }
  });
  // Render only the hardcoded rows area, keep the "已作废" static row
  var rows = workorderData.map(function(wo, idx) {
    return buildWorkorderRowHtml(wo, idx);
  }).join('');
  // Add static cancelled row at end
  rows += '<tr data-status="cancelled" data-priority="normal"><td><input type="checkbox" class="wo-row-check" data-wo-id="WO-2026032501" style="accent-color:var(--blue);cursor:pointer;"></td><td>WO-2026032501</td><td><span class="tbadge blue">📦 送物服务</span></td><td>205</td><td>孙九</td><td>需要加一床被子</td><td><div style="display:flex;flex-direction:column;gap:2px;"><span class="tbadge" style="background:var(--blue-bg);color:var(--blue);font-size:10px;">🟡普通</span><span style="font-size:10px;color:var(--text-muted);">03-25 09:00</span></div></td><td><span class="tbadge green" style="font-size:11px;padding:2px 6px;">✅ 已作废</span></td><td><span class="tbadge gray">❌ 已作废</span></td><td><span style="font-size:11px;color:var(--text-muted);">--</span></td><td>03-25 09:00</td><td><span style="font-size:11px;color:var(--text-muted);">03-25 09:30</span></td><td><button class="action-btn small green" onclick="reopenWorkorderById(\'WO-2026032501\')" style="padding:2px 6px;font-size:10px;">重新打开</button></td></tr>';
  tbody.innerHTML = rows;
  // Update SLA countdown intervals for new rows
  if (typeof updateSlaCountdowns === 'function') updateSlaCountdowns();
}

